---
// Checkout Lift Detox: /checkout-liftdetox/1-frasco  /checkout-liftdetox/3-frascos  /checkout-liftdetox/5-frascos
const { produto } = Astro.params;

const SLUG_TO_ID: Record<string, number> = {
  'kit1': 4,
  'kit2': 5,
  'kit3': 6,
  'kit4': 7,
};

const SLUG_TO_PRODUTO: Record<string, string> = {
  'kit1': 'liftdetox-kit1',
  'kit2': 'liftdetox-kit2',
  'kit3': 'liftdetox-kit3',
  'kit4': 'liftdetox-kit4',
};

const SLUG_TO_BANNER: Record<string, string> = {
  'kit1': '/liftdetox/images/kit1.jpg',
  'kit2': '/liftdetox/images/kit2.jpg',
  'kit3': '/liftdetox/images/kit3.jpg',
  'kit4': '/liftdetox/images/kit4.jpg',
};

const productId = SLUG_TO_ID[produto ?? ''];
const produtoKey = SLUG_TO_PRODUTO[produto ?? ''] ?? '';
const bannerImage = SLUG_TO_BANNER[produto ?? ''] ?? '/liftdetox/images/kit1.jpg';

// Order bump config per kit
type OrderBump = {
  title: string;
  subtitle: string;
  barText: string;
  price: string;
  image: string;
  bumpProduto: string;
  bumpValue: number; // centavos
} | null;

const ORDER_BUMPS: Record<string, OrderBump> = {
  'kit1': {
    title: '[IMPERDÍVEL] VAI PERDER? LEVE + 2 POTES POR R$ 67,90',
    subtitle: 'Aproveite essa oportunidade única de adquirir produtos incríveis com um super desconto!',
    barText: '2 POTES LIFT DETOX BLACK POR R$ 67,90',
    price: 'R$ 67,90',
    image: '/liftdetox/images/order1.jpg',
    bumpProduto: 'liftdetox-bump1',
    bumpValue: 6790,
  },
  'kit2': {
    title: 'VAI PERDER? 3 POTES PELO PREÇO DE 1',
    subtitle: 'Aproveite essa oportunidade única de adquirir produtos incríveis com um super desconto!',
    barText: '3 POTES POR R$ 137,00',
    price: 'R$ 137,00',
    image: '/liftdetox/images/order2.jpg',
    bumpProduto: 'liftdetox-bump2',
    bumpValue: 13700,
  },
  'kit3': {
    title: 'VAI PERDER? 3 POTES PELO PREÇO DE 1',
    subtitle: 'Aproveite essa oportunidade única de adquirir produtos incríveis com um super desconto!',
    barText: '3 POTES POR R$ 137,00',
    price: 'R$ 137,00',
    image: '/liftdetox/images/order2.jpg',
    bumpProduto: 'liftdetox-bump2',
    bumpValue: 13700,
  },
  'kit4': null, // no bump for kit4
};

const orderBump = ORDER_BUMPS[produto ?? ''] ?? null;

if (!productId) {
  return Astro.redirect('/liftdetox/');
}
---

<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Checkout Seguro — Lift Detox Black</title>
  <link rel="icon" type="image/png" href="/liftdetox/images/Logotipo-Lift-Detox-Black-1-150x150.png">
  <meta name="robots" content="noindex, nofollow">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/ck-liftdetox/css/style.css">
  <script src="https://api.bestfybr.com.br/v1/js"></script>

  <!-- Meta Pixel Code (Lift Detox) -->
  <script is:inline>
  !function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?
  n.callMethod.apply(n,arguments):n.queue.push(arguments)};
  if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
  n.queue=[];t=b.createElement(e);t.async=!0;t.src=v;s=b.getElementsByTagName(e)[0];
  s.parentNode.insertBefore(t,s)}(window, document,'script',
  'https://connect.facebook.net/en_US/fbevents.js');
  fbq('init', '3144701205661826');
  fbq('track', 'PageView');
  </script>
  <noscript><img height="1" width="1" style="display:none"
  src="https://www.facebook.com/tr?id=3144701205661826&ev=PageView&noscript=1"/></noscript>
  <!-- End Meta Pixel Code -->
</head>
<body>
  <!-- Header -->
  <header class="checkout-header">
    <div class="checkout-header__inner">
      <img src="/liftdetox/images/Logo-Lift-Verde.svg" alt="Lift Detox Black" class="checkout-header__logo-img">
      <div class="checkout-header__secure">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
        <div>
          <span class="checkout-header__secure-label">PAGAMENTO</span>
          <span class="checkout-header__secure-text">100% SEGURO</span>
        </div>
      </div>
    </div>
  </header>

  <!-- Countdown Urgency Bar -->
  <div class="countdown-bar">
    <div class="countdown-bar__inner">
      <div class="countdown-bar__text">
        <svg class="countdown-bar__icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5"><circle cx="12" cy="13" r="8"/><path d="M12 9v4l2.5 1.5"/><path d="M5 3L2 6"/><path d="M22 6l-3-3"/></svg>
        <div>
          <strong>O preço promocional vai sair do ar em breve</strong>
          <span>Preço promocional encerrará em:</span>
        </div>
      </div>
      <div class="countdown-bar__timer" id="countdown-timer">
        <div class="countdown-bar__group">
          <div class="countdown-bar__digit" id="cd-h1">0</div>
          <div class="countdown-bar__digit" id="cd-h2">0</div>
        </div>
        <span class="countdown-bar__sep">:</span>
        <div class="countdown-bar__group">
          <div class="countdown-bar__digit" id="cd-m1">0</div>
          <div class="countdown-bar__digit" id="cd-m2">0</div>
        </div>
        <span class="countdown-bar__sep">:</span>
        <div class="countdown-bar__group">
          <div class="countdown-bar__digit" id="cd-s1">0</div>
          <div class="countdown-bar__digit" id="cd-s2">0</div>
        </div>
      </div>
    </div>
  </div>

  <!-- Kit Banner Image -->
  <div class="checkout-kit-banner">
    <img src={bannerImage} alt="Kit selecionado" class="checkout-kit-banner__img">
  </div>

  <!-- Banner -->
  <div class="checkout-banner">
    Parcelamento em até 12x no cartão de crédito.<br>
    <strong>PIX com 5% de desconto e envio prioritário.</strong> Aproveite!
  </div>

  <!-- Main Layout -->
  <div class="checkout-container">
    <main class="checkout-steps">

      <!-- Step 1: Dados pessoais -->
      <section class="step-card step-card--active" id="section-customer" data-step="1">
        <div class="step-card__header">
          <h3 class="step-card__title">Dados pessoais</h3>
          <span class="step-card__edit" id="edit-step-1" style="display:none;">Editar</span>
        </div>
        <p class="step-card__subtitle">Pedimos apenas as informações essenciais para concluir sua compra com segurança.</p>
        <div class="step-card__summary" id="summary-step-1" style="display:none;"></div>
        <div class="step-card__body" id="body-step-1">
          <div class="form-grid">
            <div class="form-group full">
              <label for="customer-name">Nome completo</label>
              <input type="text" id="customer-name" placeholder="Ex: Mariana Cardoso Silva" required>
            </div>
            <div class="form-group full">
              <label for="customer-email">E-mail</label>
              <input type="email" id="customer-email" placeholder="ex: marianacardoso@gmail.com" required>
            </div>
            <div class="form-group">
              <label for="customer-cpf">CPF <svg class="info-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg></label>
              <input type="text" id="customer-cpf" placeholder="000.000.000-00" required>
            </div>
            <div class="form-group">
              <label for="customer-phone">Celular/Whatsapp</label>
              <div class="phone-input-wrapper">
                <span class="phone-prefix">+55</span>
                <input type="tel" id="customer-phone" placeholder="(00) 00000-0000" required>
              </div>
            </div>
          </div>
          <button class="btn-step" id="btn-step-1" type="button">
            Continuar <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </button>
        </div>
      </section>

      <!-- Step 2: Entrega -->
      <section class="step-card step-card--locked" id="section-address" data-step="2">
        <div class="step-card__header">
          <h3 class="step-card__title">Entrega</h3>
          <span class="step-card__edit" id="edit-step-2" style="display:none;">Editar</span>
        </div>
        <p class="step-card__subtitle step-card__locked-msg" id="locked-msg-2">Preencha suas informações pessoais para continuar</p>
        <div class="step-card__summary" id="summary-step-2" style="display:none;"></div>
        <div class="step-card__body" id="body-step-2" style="display:none;">
          <div class="form-grid">
            <div class="form-group">
              <label for="address-cep">CEP</label>
              <input type="text" id="address-cep" placeholder="00000-000" inputmode="numeric" maxlength="9" required>
            </div>
          </div>
          <div id="address-fields" style="display:none;">
            <div class="form-grid">
              <div class="form-group full">
                <label for="address-street">Rua</label>
                <input type="text" id="address-street" placeholder="Nome da rua" required>
              </div>
              <div class="form-group small">
                <label for="address-number">Número</label>
                <input type="text" id="address-number" placeholder="123" required>
              </div>
              <div class="form-group">
                <label for="address-complement">Complemento</label>
                <input type="text" id="address-complement" placeholder="Apto, bloco...">
              </div>
              <div class="form-group">
                <label for="address-neighborhood">Bairro</label>
                <input type="text" id="address-neighborhood" placeholder="Bairro" required>
              </div>
              <div class="form-group">
                <label for="address-city">Cidade</label>
                <input type="text" id="address-city" placeholder="Cidade" required>
              </div>
              <div class="form-group small">
                <label for="address-state">Estado</label>
                <select id="address-state" required>
                  <option value="">UF</option>
                  <option value="AC">AC</option><option value="AL">AL</option>
                  <option value="AP">AP</option><option value="AM">AM</option>
                  <option value="BA">BA</option><option value="CE">CE</option>
                  <option value="DF">DF</option><option value="ES">ES</option>
                  <option value="GO">GO</option><option value="MA">MA</option>
                  <option value="MT">MT</option><option value="MS">MS</option>
                  <option value="MG">MG</option><option value="PA">PA</option>
                  <option value="PB">PB</option><option value="PR">PR</option>
                  <option value="PE">PE</option><option value="PI">PI</option>
                  <option value="RJ">RJ</option><option value="RN">RN</option>
                  <option value="RS">RS</option><option value="RO">RO</option>
                  <option value="RR">RR</option><option value="SC">SC</option>
                  <option value="SP">SP</option><option value="SE">SE</option>
                  <option value="TO">TO</option>
                </select>
              </div>
            </div>
            <div id="shipping-options" class="shipping-options">
              <p class="shipping-options__title">Escolha uma forma de entrega:</p>
              <label class="shipping-option shipping-option--selected">
                <input type="radio" name="shipping" value="pac" data-price="0" data-label="Correios-PAC" checked>
                <span class="shipping-option__radio"></span>
                <div class="shipping-option__info">
                  <span class="shipping-option__name">Correios-PAC</span>
                  <span class="shipping-option__days">3 a 9 dias <img src="https://cdn.shopify.com/s/files/1/0782/3186/3542/files/correios.png?v=1773700748" alt="Correios" class="shipping-option__logo"></span>
                </div>
                <span class="shipping-option__price shipping-option__price--free">Grátis</span>
              </label>
              <label class="shipping-option">
                <input type="radio" name="shipping" value="sedex" data-price="2744" data-label="Correios-SEDEX">
                <span class="shipping-option__radio"></span>
                <div class="shipping-option__info">
                  <span class="shipping-option__name">Correios-SEDEX</span>
                  <span class="shipping-option__days">2 a 5 dias <img src="https://cdn.shopify.com/s/files/1/0782/3186/3542/files/sedex.png?v=1773700748" alt="SEDEX" class="shipping-option__logo"></span>
                </div>
                <span class="shipping-option__price">R$ 27,44</span>
              </label>
              <label class="shipping-option">
                <input type="radio" name="shipping" value="full" data-price="3925" data-label="FULL-Dia Seguinte">
                <span class="shipping-option__radio"></span>
                <div class="shipping-option__info">
                  <span class="shipping-option__name">FULL-Dia Seguinte</span>
                  <span class="shipping-option__days">1 a 2 dias <svg class="shipping-option__logo-svg" width="41" height="13" viewBox="0 0 41 13" xmlns="http://www.w3.org/2000/svg"><path fill-rule="nonzero" fill="#00a650" d="M2.628 0h5.255L5.255 4.643h4.38L2.628 13l1.751-5.571H0L2.628 0zm11.589 9.533h-1.959l1.674-7.515H19.5l-.376 1.69h-3.61l-.25 1.172h3.519l-.376 1.69h-3.53l-.66 2.963zm9.468.136c-2.334 0-3.484-1.105-3.484-2.682 0-.124.034-.383.057-.496l1.002-4.473h1.992l-.99 4.428c-.012.057-.034.18-.034.316.011.62.49 1.217 1.457 1.217 1.048 0 1.583-.654 1.776-1.533l.991-4.428h1.981l-.99 4.462c-.41 1.825-1.412 3.189-3.758 3.189zm10.118-.136h-5.01l1.673-7.515h1.959l-1.287 5.825h3.04l-.375 1.69zm6.678 0h-5.01l1.674-7.515h1.959l-1.287 5.825h3.04l-.376 1.69z"/></svg></span>
                </div>
                <span class="shipping-option__price">R$ 39,25</span>
              </label>
            </div>
          </div>
          <button class="btn-step" id="btn-step-2" type="button">
            Continuar <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </button>
        </div>
      </section>

      <!-- Step 3: Pagamento -->
      <section class="step-card step-card--locked" id="section-payment" data-step="3">
        <div class="step-card__header">
          <h3 class="step-card__title">Opção de pagamento</h3>
        </div>
        <p class="step-card__subtitle step-card__locked-msg" id="locked-msg-3">Preencha suas informações de entrega para continuar</p>
        <div class="step-card__body" id="body-step-3" style="display:none;">
          <div class="payment-tabs">
            <label class="payment-tab active" data-method="credit_card">
              <input type="radio" name="payment-method" value="credit_card" checked>
              <span class="payment-tab__radio"></span>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
              <span class="payment-tab__label">Cartão de crédito</span>
            </label>
            <label class="payment-tab" data-method="pix">
              <input type="radio" name="payment-method" value="pix">
              <span class="payment-tab__radio"></span>
              <svg width="20" height="20" viewBox="0 0 901 900" fill="#32BCAD" xmlns="http://www.w3.org/2000/svg"><g transform="translate(0 900) scale(.1 -.1)"><path d="m4265 8986c-216-42-357-99-536-217-83-54-204-172-1001-968-500-498-908-909-908-913 0-5 92-8 204-8 288 0 449-33 646-132 186-94 194-101 985-889 413-411 766-755 785-765 49-26 181-26 230 0 19 10 368 350 775 755 642 640 752 746 834 800 241 159 431 218 735 228l178 6-888 889c-489 489-920 913-959 943-157 121-324 202-519 252-88 22-127 26-296 29-136 2-216-1-265-10z"/><path d="m861 5935c-485-487-577-584-630-664-102-154-154-272-199-450-25-99-27-121-27-321 0-191 3-225 24-310 49-199 134-377 256-535 30-38 299-315 598-614l544-543 359 1c403 2 467 8 607 55 204 69 179 48 1022 887 759 756 760 756 845 798 197 96 409 94 603-5 66-35 130-95 812-774 446-444 766-756 807-784 79-56 187-107 289-137 68-20 102-23 419-29 190-3 352-9 360-13 11-5 167 145 586 565 488 490 580 587 633 667 34 52 73 116 87 142 195 385 195 873 0 1258-14 26-53 90-87 142-53 80-145 177-633 667-419 420-575 570-586 565-8-4-170-10-360-13-317-6-351-9-419-29-102-30-210-81-289-137-40-28-364-343-812-789-802-798-778-776-930-823-175-53-368-27-525 70-29 18-367 347-805 782-837 833-813 812-1017 882-136 46-219 54-616 56l-348 3-568-570z"/><path d="m4465 3913c-47-14-101-65-805-767-796-793-804-800-990-894-196-99-359-132-647-132-112 0-203-3-203-8 0-4 408-415 908-913 797-796 918-914 1001-968 154-102 272-154 450-199 99-25 121-27 321-27 191 0 225 3 310 24 199 49 377 134 535 256 39 30 470 454 959 943l888 889-178 6c-304 10-494 69-735 228-82 54-193 161-839 805-722 719-747 743-799 758-67 19-110 19-176-1z"/></g></svg>
              <span class="payment-tab__label">PIX</span>
              <span class="payment-tab__badges">
                <span class="badge badge--green">APROVAÇÃO IMEDIATA</span>
                <span class="badge badge--red">5% DE DESCONTO</span>
              </span>
            </label>
          </div>

          <!-- Cartão de crédito -->
          <div class="payment-content active" id="payment-credit_card">
            <div class="form-grid">
              <div class="form-group full">
                <label for="card-number">Número do cartão</label>
                <input type="text" id="card-number" placeholder="0000 0000 0000 0000" maxlength="19" required>
              </div>
              <div class="form-group full">
                <label for="card-holder">Nome no cartão</label>
                <input type="text" id="card-holder" placeholder="Como está no cartão" required>
              </div>
              <div class="form-group">
                <label for="card-expiry">Validade</label>
                <input type="text" id="card-expiry" placeholder="MM/AA" maxlength="5" required>
              </div>
              <div class="form-group">
                <label for="card-cvv">CVV</label>
                <input type="text" id="card-cvv" placeholder="123" maxlength="4" required>
              </div>
              <div class="form-group full">
                <label for="card-installments">Parcelas</label>
                <select id="card-installments">
                  <option value="1">1x sem juros</option>
                  <option value="2">2x sem juros</option>
                  <option value="3">3x sem juros</option>
                  <option value="4">4x</option>
                  <option value="5">5x</option>
                  <option value="6">6x</option>
                  <option value="7">7x</option>
                  <option value="8">8x</option>
                  <option value="9">9x</option>
                  <option value="10">10x</option>
                  <option value="11">11x</option>
                  <option value="12">12x</option>
                </select>
              </div>
            </div>
          </div>

          <!-- PIX -->
          <div class="payment-content" id="payment-pix">
            <div class="pix-info">
              <h4 class="pix-info__title">A confirmação do seu pagamento é mais rápida</h4>
              <p>Após clicar em 'Finalizar Compra' você terá 30 minutos para pagar com Pix usando QR Code ou código que será exibido. A confirmação é instantânea.</p>
              <p class="pix-info__value">Valor no Pix: <strong id="pix-discount-value">R$ 0,00</strong></p>
            </div>
          </div>

          {/* Order Bump */}
          {orderBump && (
            <div class="order-bump" id="order-bump">
              <div class="order-bump__header">
                <strong class="order-bump__title">{orderBump.title}</strong>
                <p class="order-bump__subtitle">{orderBump.subtitle}</p>
              </div>
              <div class="order-bump__bar">
                <span>{orderBump.barText}</span>
              </div>
              <div class="order-bump__body">
                <div class="order-bump__image">
                  <img src={orderBump.image} alt="Order Bump" />
                </div>
                <div class="order-bump__details">
                  <p class="order-bump__price-label">por apenas: <strong class="order-bump__price">{orderBump.price}</strong></p>
                  <button class="order-bump__btn" id="btn-order-bump" type="button"
                    data-bump-produto={orderBump.bumpProduto}
                    data-bump-value={String(orderBump.bumpValue)}>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
                    ADICIONAR AO CARRINHO
                  </button>
                </div>
              </div>
            </div>
          )}

          <button class="btn-pay" id="btn-pay" type="button">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
            <span class="btn-text">Finalizar Compra</span>
            <span class="btn-loading" style="display:none;">
              <span class="spinner"></span> Processando...
            </span>
          </button>
        </div>
      </section>

      <!-- Mensagem de erro -->
      <div class="error-message" id="error-message" style="display:none;"></div>

      <!-- Resultado do pagamento -->
      <div class="payment-result" id="payment-result" style="display:none;">
        <div class="result-icon success" id="result-icon-success" style="display:none;">
          <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M9 12l2 2 4-4"/></svg>
        </div>
