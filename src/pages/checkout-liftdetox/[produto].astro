  <script is:inline define:vars={{ productId, produtoKey }}>
    // Inject product ID and produto key into URL so checkout.js can read it
    if (!new URLSearchParams(window.location.search).get('product')) {
      var url = new URL(window.location.href);
      url.searchParams.set('product', String(productId));
      url.searchParams.set('produto', produtoKey);
      history.replaceState(null, '', url.toString());
    }
  </script>
  <script is:inline src="/ck/js/checkout.js"></script>

  <!-- Countdown Timer Script -->
  <script is:inline>
  (function() {
    var DURATION = 15 * 60; // 15 minutes in seconds
    var STORAGE_KEY = 'liftdetox_countdown_end';
    var stored = sessionStorage.getItem(STORAGE_KEY);
    var endTime;
    if (stored && Number(stored) > Date.now()) {
      endTime = Number(stored);
    } else {
      endTime = Date.now() + DURATION * 1000;
      sessionStorage.setItem(STORAGE_KEY, String(endTime));
    }

    function pad2(n) { return n < 10 ? '0' + n : String(n); }

    function tick() {
      var diff = Math.max(0, Math.floor((endTime - Date.now()) / 1000));
      var h = Math.floor(diff / 3600);
      var m = Math.floor((diff % 3600) / 60);
      var s = diff % 60;
      var hh = pad2(h), mm = pad2(m), ss = pad2(s);
      document.getElementById('cd-h1').textContent = hh[0];
      document.getElementById('cd-h2').textContent = hh[1];
      document.getElementById('cd-m1').textContent = mm[0];
      document.getElementById('cd-m2').textContent = mm[1];
      document.getElementById('cd-s1').textContent = ss[0];
      document.getElementById('cd-s2').textContent = ss[1];
      if (diff > 0) requestAnimationFrame(function(){ setTimeout(tick, 1000); });
    }
    tick();
  })();
  </script>

  <!-- Order Bump Script -->
  <script is:inline>
  (function() {
    var btn = document.getElementById('btn-order-bump');
    if (!btn) return;

    var bumpValue = parseInt(btn.getAttribute('data-bump-value') || '0', 10);
    var added = false;

    btn.addEventListener('click', function() {
      if (added) return;
      added = true;

      // Visual feedback
      btn.textContent = '✓ ADICIONADO';
      btn.classList.add('order-bump__btn--added');
      var bumpEl = document.getElementById('order-bump');
      if (bumpEl) bumpEl.classList.add('order-bump--added');

      // Update order totals
      var subtotalEl = document.getElementById('order-subtotal-value');
      var totalEl = document.getElementById('order-total-value');
      if (subtotalEl && totalEl) {
        var currentSubtotal = parseFloat(subtotalEl.textContent.replace('R$', '').replace('.', '').replace(',', '.').trim()) || 0;
        var newSubtotal = currentSubtotal + (bumpValue / 100);
        var fmtSub = 'R$ ' + newSubtotal.toFixed(2).replace('.', ',');
        subtotalEl.textContent = fmtSub;

        // Recalculate total (subtotal + shipping)
        var shippingEl = document.getElementById('order-shipping-value');
        var shippingVal = 0;
        if (shippingEl) {
          var shTxt = shippingEl.textContent.replace('R$', '').replace('.', '').replace(',', '.').trim();
          shippingVal = parseFloat(shTxt) || 0;
        }
        var newTotal = newSubtotal + shippingVal;
        totalEl.textContent = 'R$ ' + newTotal.toFixed(2).replace('.', ',');
      }

      // Store bump in URL params so checkout.js can send it
      var url = new URL(window.location.href);
      url.searchParams.set('bump', btn.getAttribute('data-bump-produto') || '');
      url.searchParams.set('bumpValue', String(bumpValue));
      history.replaceState(null, '', url.toString());
    });
  })();
  </script>
