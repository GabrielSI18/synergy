  <script is:inline>
    // ===== GALLERY =====
    var slides = [
      { type: 'image', src: 'https://madeliebrasil.com/cdn/shop/files/br-11134207-7r98o-m82v867w1gk111.jpg?v=1764562749&width=1000', thumb: 'https://madeliebrasil.com/cdn/shop/files/br-11134207-7r98o-m82v867w1gk111.jpg?v=1764562749&width=150', alt: 'Branco' },
      { type: 'image', src: 'https://madeliebrasil.com/cdn/shop/files/br-11134207-7r98o-m82v867w2v4h0d.jpg?v=1764562749&width=1000', thumb: 'https://madeliebrasil.com/cdn/shop/files/br-11134207-7r98o-m82v867w2v4h0d.jpg?v=1764562749&width=150', alt: 'Azul' },
      { type: 'image', src: 'https://madeliebrasil.com/cdn/shop/files/br-11134207-7r98o-mdo9os98lqdtaf.jpg?v=1764562749&width=1000', thumb: 'https://madeliebrasil.com/cdn/shop/files/br-11134207-7r98o-mdo9os98lqdtaf.jpg?v=1764562749&width=150', alt: 'Rosa' },
      { type: 'image', src: 'https://madeliebrasil.com/cdn/shop/files/br-11134207-7r98o-mdo9os98n4y988.jpg?v=1764562750&width=1000', thumb: 'https://madeliebrasil.com/cdn/shop/files/br-11134207-7r98o-mdo9os98n4y988.jpg?v=1764562750&width=150', alt: 'Roxo' },
      { type: 'image', src: 'https://madeliebrasil.com/cdn/shop/files/Prancheta1.png?v=1764562750&width=800', thumb: 'https://madeliebrasil.com/cdn/shop/files/Prancheta1.png?v=1764562750&width=150', alt: 'Prancheta 1' },
      { type: 'image', src: 'https://madeliebrasil.com/cdn/shop/files/Prancheta2.png?v=1764562751&width=800', thumb: 'https://madeliebrasil.com/cdn/shop/files/Prancheta2.png?v=1764562751&width=150', alt: 'Prancheta 2' },
      { type: 'image', src: 'https://madeliebrasil.com/cdn/shop/files/Prancheta3.png?v=1764562750&width=800', thumb: 'https://madeliebrasil.com/cdn/shop/files/Prancheta3.png?v=1764562750&width=150', alt: 'Prancheta 3' },
      { type: 'image', src: 'https://madeliebrasil.com/cdn/shop/files/Prancheta4.png?v=1764562751&width=800', thumb: 'https://madeliebrasil.com/cdn/shop/files/Prancheta4.png?v=1764562751&width=150', alt: 'Prancheta 4' },
      { type: 'image', src: 'https://madeliebrasil.com/cdn/shop/files/Prancheta5.png?v=1764562750&width=800', thumb: 'https://madeliebrasil.com/cdn/shop/files/Prancheta5.png?v=1764562750&width=150', alt: 'Prancheta 5' },
      { type: 'video', src: 'https://cdn.shopify.com/videos/c/o/v/23d17c1bfa954fb09d854cdbce308f03.mp4', thumb: 'https://madeliebrasil.com/cdn/shop/files/Prancheta5.png?v=1764562750&width=150', alt: 'Video 1' },
      { type: 'image', src: 'https://madeliebrasil.com/cdn/shop/files/Prancheta6.png?v=1764562752&width=800', thumb: 'https://madeliebrasil.com/cdn/shop/files/Prancheta6.png?v=1764562752&width=150', alt: 'Prancheta 6' },
      { type: 'image', src: 'https://madeliebrasil.com/cdn/shop/files/Prancheta7.png?v=1764562751&width=800', thumb: 'https://madeliebrasil.com/cdn/shop/files/Prancheta7.png?v=1764562751&width=150', alt: 'Prancheta 7' },
      { type: 'image', src: 'https://madeliebrasil.com/cdn/shop/files/Prancheta8.png?v=1764562751&width=800', thumb: 'https://madeliebrasil.com/cdn/shop/files/Prancheta8.png?v=1764562751&width=150', alt: 'Prancheta 8' },
      { type: 'image', src: 'https://madeliebrasil.com/cdn/shop/files/Prancheta9.png?v=1764562752&width=800', thumb: 'https://madeliebrasil.com/cdn/shop/files/Prancheta9.png?v=1764562752&width=150', alt: 'Prancheta 9' },
      { type: 'image', src: 'https://madeliebrasil.com/cdn/shop/files/Prancheta10.png?v=1764562751&width=800', thumb: 'https://madeliebrasil.com/cdn/shop/files/Prancheta10.png?v=1764562751&width=150', alt: 'Prancheta 10' },
      { type: 'video', src: 'https://cdn.shopify.com/videos/c/o/v/808e25a9448e4ea5b2b53965eef7da2c.mp4', thumb: 'https://madeliebrasil.com/cdn/shop/files/Prancheta10.png?v=1764562751&width=150', alt: 'Video 2' },
    ];

    var cur = 0;
    var sliderEl = document.getElementById('gallerySlider');
    var dotsEl = document.getElementById('galleryDots');
    var thumbsEl = document.getElementById('galleryThumbs');

    slides.forEach(function(s, i) {
      var d = document.createElement('div');
      d.className = 'gallery-slide';
      if (s.type === 'video') {
        d.innerHTML = '<video autoplay loop muted playsinline><source src="' + s.src + '" type="video/mp4"></video>';
      } else {
        d.innerHTML = '<img src="' + s.src + '" alt="' + s.alt + '">';
      }
      sliderEl.appendChild(d);

      var dot = document.createElement('div');
      dot.className = 'gallery-dot' + (i === 0 ? ' active' : '');
      dot.onclick = function() { goTo(i); };
      dotsEl.appendChild(dot);

      var th = document.createElement('div');
      th.className = 'gallery-thumb' + (i === 0 ? ' active' : '') + (s.type === 'video' ? ' is-video' : '');
      th.innerHTML = '<img src="' + s.thumb + '" alt="' + s.alt + '">';
      th.onclick = function() { goTo(i); };
      thumbsEl.appendChild(th);
    });

    function goTo(i) {
      cur = i;
      sliderEl.scrollTo({ left: sliderEl.offsetWidth * i, behavior: 'smooth' });
      document.querySelectorAll('.gallery-dot').forEach(function(d, j) { d.classList.toggle('active', j === i); });
      document.querySelectorAll('.gallery-thumb').forEach(function(t, j) { t.classList.toggle('active', j === i); });
      sliderEl.querySelectorAll('video').forEach(function(v, j) { j === i ? v.play() : v.pause(); });
    }

    document.getElementById('prevBtn').onclick = function() { goTo(cur > 0 ? cur - 1 : slides.length - 1); };
    document.getElementById('nextBtn').onclick = function() { goTo(cur < slides.length - 1 ? cur + 1 : 0); };

    // Swipe touch
    var tx = 0;
    sliderEl.addEventListener('touchstart', function(e) { tx = e.changedTouches[0].screenX; }, { passive: true });
    sliderEl.addEventListener('touchend', function(e) {
      var diff = tx - e.changedTouches[0].screenX;
      if (Math.abs(diff) > 40) {
        diff > 0 ? goTo(cur < slides.length - 1 ? cur + 1 : 0) : goTo(cur > 0 ? cur - 1 : slides.length - 1);
      }
    }, { passive: true });

    // Atualiza dots/thumbs ao scrollar manualmente
    sliderEl.addEventListener('scroll', function() {
      var i = Math.round(sliderEl.scrollLeft / sliderEl.offsetWidth);
      if (i !== cur) {
        cur = i;
        document.querySelectorAll('.gallery-dot').forEach(function(d, j) { d.classList.toggle('active', j === i); });
        document.querySelectorAll('.gallery-thumb').forEach(function(t, j) { t.classList.toggle('active', j === i); });
      }
    }, { passive: true });

    // ===== ACCORDION =====
    document.querySelectorAll('.accordion-header').forEach(function(button) {
      button.addEventListener('click', function() {
        var item = button.parentElement;
        item.classList.toggle('active');
        var content = item.querySelector('.accordion-content');
        if (item.classList.contains('active')) {
          content.style.maxHeight = content.scrollHeight + 'px';
        } else {
          content.style.maxHeight = null;
        }
      });
    });

    // ===== PRICING =====
    document.querySelectorAll('.price-card').forEach(function(card) {
      card.addEventListener('click', function() {
        document.querySelectorAll('.price-card').forEach(function(c) { c.classList.remove('selected'); });
        card.classList.add('selected');
        document.getElementById('flPr').textContent = card.dataset.label;
        document.getElementById('flWs').textContent = card.dataset.was;
      });
    });

    // ===== CHECKOUT LINKS =====
    var CHECKOUT_URLS = [
      '/checkout/1-unidade',       // 1 Unidade
      '/checkout/2-unidades',      // 2 Unidades
      '/checkout/kit-profissional' // Kit Profissional
    ];

    window.goOffers = function() {
      var cards = document.querySelectorAll('.price-card');
      var idx = 2; // padrão: Kit Profissional (já vem selecionado)
      cards.forEach(function(c, i) {
        if (c.classList.contains('selected')) idx = i;
      });
      window.location.href = CHECKOUT_URLS[idx];
    };

    // ===== CROSS-SELL: redireciona selecionando o card correto =====
    // cardIdx: 1 = "2 Unidades" (comprar junto), 2 = "Kit Profissional" (brinde grátis)
    window.xsellGo = function(cardIdx) {
      var cards = document.querySelectorAll('.price-card');
      cards.forEach(function(c) { c.classList.remove('selected'); });
      if (cards[cardIdx]) cards[cardIdx].classList.add('selected');
      window.location.href = CHECKOUT_URLS[cardIdx];
    };

    // ===== FLOAT CTA VISIBILITY =====
    var fc = document.getElementById('floatCta');
    var ps = document.getElementById('ofertas');
    if (window.innerWidth < 768) {
      fc.style.transition = 'transform 0.3s ease';
      var chk = function() {
        var r = ps.getBoundingClientRect();
        fc.style.transform = (r.bottom < 0 || r.top > window.innerHeight) ? 'translateY(0)' : 'translateY(100%)';
      };
      window.addEventListener('scroll', chk, { passive: true });
      chk();
    }

    // ===== AUTO-PLAY DUAL VIDEOS =====
    (function() {
      function safePlay(v) {
        try {
          v.muted = true;
          v.playsInline = true;
          v.setAttribute('playsinline', '');
          v.setAttribute('muted', '');
          var p = v.play();
          if (p !== undefined) p.catch(function(){});
        } catch(e) {}
      }
      var v1 = document.getElementById('video1');
      var v2 = document.getElementById('video2');
      if (v1) safePlay(v1);
      if (v2) safePlay(v2);
    })();

    // ===== PAGINATION (visual only) =====
    document.querySelectorAll('.reviews-pagination .page-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        if (!this.classList.contains('current')) {
          this.animate([{opacity:1},{opacity:0.6},{opacity:1}], {duration:260});
        }
      });
    });

    // ===== MODAIS DO FOOTER =====
    window.openModal = function(id) {
      document.getElementById(id).classList.add('active');
      document.body.style.overflow = 'hidden';
    };
    window.closeModal = function(id) {
      document.getElementById(id).classList.remove('active');
      document.body.style.overflow = '';
    };
    // Fechar ao clicar fora do box
    document.querySelectorAll('.modal-overlay').forEach(function(overlay) {
      overlay.addEventListener('click', function(e) {
        if (e.target === overlay) {
          overlay.classList.remove('active');
          document.body.style.overflow = '';
        }
      });
    });
    // Fechar com ESC
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        document.querySelectorAll('.modal-overlay.active').forEach(function(m) {
          m.classList.remove('active');
        });
        document.body.style.overflow = '';
      }
    });
  </script>

</body>
</html>
