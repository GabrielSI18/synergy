---
// Bettdow AirLux Pro - Landing Page
---

<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>Bettdow AirLux Pro - Secador de Alta Velocidade com Íons Negativos, 1500W, 110.000 rpm</title>
  <meta name="description" content="Secador de cabelo profissional Bettdow AirLux Pro com motor digital de 110.000 rpm, tecnologia de íons negativos, 1500W.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  <style>
    :root {
      --black: #1a1a1a;
      --white: #ffffff;
      --g50: #fafafa;
      --g100: #f5f5f5;
      --g200: #e5e5e5;
      --g300: #d4d4d4;
      --g400: #a3a3a3;
      --g500: #737373;
      --g600: #525252;
      --g700: #404040;
      --g800: #262626;
      --g900: #171717;
      --green: #22c55e;
      --green-light: #f0fdf4;
      --red: #ef4444;
      --gold: #f5a623;
      --yellow: #f0c040;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      line-height: 1.6;
      color: var(--black);
      background: var(--white);
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
      -webkit-text-size-adjust: 100%;
    }

    img, video { max-width: 100%; height: auto; display: block; }
    a { text-decoration: none; color: inherit; }
    button { cursor: pointer; border: none; font-family: inherit; }

    /* ===== TOPBAR ===== */
    .topbar {
      background: var(--black);
      color: var(--white);
      text-align: center;
      padding: 10px 16px;
      font-size: 12px;
      font-weight: 500;
      letter-spacing: 0.3px;
      line-height: 1.4;
    }
    .topbar span { color: var(--yellow); font-weight: 700; }

    /* ===== HEADER ===== */
    .header {
      background: var(--white);
      padding: 14px 16px;
      border-bottom: 1px solid var(--g200);
      position: sticky;
      top: 0;
      z-index: 100;
    }
    .header-inner {
      max-width: 1200px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .logo {
      font-size: 24px;
      font-weight: 800;
      color: var(--black);
      letter-spacing: -1px;
    }

    /* ===== GALLERY ===== */
    .gallery-wrap {
      background: var(--white);
      position: relative;
      overflow: hidden;
    }
    .gallery-slider {
      display: flex;
      transition: transform 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
      will-change: transform;
    }
    .gallery-slide {
      min-width: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      background: var(--white);
    }
    .gallery-slide img, .gallery-slide video {
      width: 100%;
      height: auto;
      max-height: 75vh;
      object-fit: contain;
    }
    .gallery-nav {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      width: 40px;
      height: 40px;
      background: rgba(255,255,255,0.92);
      border: none;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 18px;
      color: var(--g700);
      z-index: 10;
      box-shadow: 0 2px 12px rgba(0,0,0,0.1);
      transition: all 0.2s;
    }
    .gallery-nav:active { transform: translateY(-50%) scale(0.92); }
    .gallery-nav.prev { left: 12px; }
    .gallery-nav.next { right: 12px; }
    .gallery-dots {
      display: flex;
      justify-content: center;
      gap: 6px;
      padding: 12px 0;
      background: var(--white);
    }
    .gallery-dot {
      width: 8px; height: 8px;
      border-radius: 50%;
      background: var(--g300);
      transition: all 0.25s;
      cursor: pointer;
    }
    .gallery-dot.active {
      background: var(--black);
      width: 24px;
      border-radius: 4px;
    }
    .gallery-thumbs {
      display: flex;
      gap: 8px;
      padding: 8px 16px 12px;
      overflow-x: auto;
      scrollbar-width: none;
      background: var(--white);
    }
    .gallery-thumbs::-webkit-scrollbar { display: none; }
    .gallery-thumb {
      min-width: 56px; width: 56px; height: 56px;
      border-radius: 8px;
      overflow: hidden;
      border: 2px solid transparent;
      cursor: pointer;
      flex-shrink: 0;
      transition: all 0.2s;
      opacity: 0.6;
    }
    .gallery-thumb.active { border-color: var(--black); opacity: 1; }
    .gallery-thumb img { width: 100%; height: 100%; object-fit: cover; }
    .gallery-thumb.is-video { position: relative; }
    .gallery-thumb.is-video::after {
      content: '▶';
      position: absolute;
      top: 50%; left: 50%;
      transform: translate(-50%, -50%);
      font-size: 14px;
      color: white;
      text-shadow: 0 1px 3px rgba(0,0,0,0.6);
    }

    /* ===== PRODUCT INFO ===== */
    .product-info { padding: 16px 16px 8px; }
    .rating-row {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 10px;
    }
    .stars { color: var(--gold); font-size: 15px; letter-spacing: 1px; }
    .rating-text { font-size: 13px; color: var(--g500); font-weight: 500; }
    .product-title {
      font-size: 19px;
      font-weight: 700;
      line-height: 1.35;
      color: var(--black);
      margin-bottom: 10px;
    }
    .product-desc {
      font-size: 14px;
      color: var(--g600);
      line-height: 1.6;
      margin-bottom: 16px;
    }

    /* ===== BENEFITS ===== */
    .benefits {
      list-style: none;
      padding: 0 16px 20px;
      display: flex;
      flex-direction: column;
      gap: 8px;
    }
    .benefits li {
      font-size: 14px;
      color: var(--g700);
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 8px 12px;
      background: var(--g50);
      border-radius: 10px;
    }
    .benefits li .em { font-size: 18px; flex-shrink: 0; }

    /* ===== PRICING ===== */
    .pricing-section {
      padding: 28px 16px;
      background: var(--g100);
    }
    .pricing-header {
      text-align: center;
      margin-bottom: 20px;
    }
    .pricing-header h2 {
      font-size: 20px;
      font-weight: 800;
      color: var(--black);
    }
    .pricing-cards {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    .price-card {
      background: var(--white);
      border: 2px solid var(--g200);
      border-radius: 14px;
      padding: 16px 14px 16px 48px;
      position: relative;
      transition: all 0.25s;
      cursor: pointer;
    }
    .price-card.selected {
      border-color: var(--black);
      box-shadow: 0 4px 24px rgba(0,0,0,0.08);
    }
    .price-card .bdg {
      position: absolute;
      top: -11px;
      right: 16px;
      padding: 4px 12px;
      border-radius: 20px;
      font-size: 10px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    .bdg-gr { background: var(--green); color: white; }
    .bdg-dk { background: var(--black); color: white; }
    .price-card .c-top {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 4px;
    }
    .price-card .c-name { font-size: 16px; font-weight: 700; color: var(--black); }
    .price-card .c-eco {
      font-size: 11px;
      font-weight: 600;
      color: var(--green);
      background: var(--green-light);
      padding: 3px 10px;
      border-radius: 6px;
    }
    .price-card .c-desc { font-size: 12px; color: var(--g500); margin-bottom: 8px; }
    .price-card .c-prices { display: flex; align-items: baseline; gap: 10px; }
    .price-card .p-now { font-size: 24px; font-weight: 800; color: var(--black); }
    .price-card .p-was { font-size: 14px; color: var(--g400); text-decoration: line-through; }
    .price-card .radio {
      position: absolute;
      left: 16px;
      top: 50%;
      transform: translateY(-50%);
      width: 20px; height: 20px;
      border-radius: 50%;
      border: 2px solid var(--g300);
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.2s;
    }
    .price-card.selected .radio { border-color: var(--black); }
    .price-card.selected .radio::after {
      content: '';
      width: 10px; height: 10px;
      border-radius: 50%;
      background: var(--black);
    }

    /* ===== CTA ===== */
    .cta-wrap { padding: 20px 16px; }
    .cta-btn {
      display: block;
      width: 100%;
      padding: 16px;
      background: var(--black);
      color: var(--white);
      text-align: center;
      font-size: 16px;
      font-weight: 700;
      border-radius: 14px;
      letter-spacing: 0.3px;
      transition: all 0.2s;
      position: relative;
      overflow: hidden;
    }
    .cta-btn:hover { background: var(--g800); }
    .cta-btn:active { transform: scale(0.98); }
    .cta-btn .sh {
      position: absolute;
      top: 0; left: -100%;
      width: 100%; height: 100%;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.15), transparent);
      animation: shimmer 2.5s infinite;
    }
    @keyframes shimmer { 100% { left: 100%; } }

    .cta-trust {
      display: flex;
      justify-content: center;
      gap: 16px;
      margin-top: 14px;
      flex-wrap: wrap;
    }
    .cta-trust-item {
      display: flex;
      align-items: center;
      gap: 4px;
      font-size: 11px;
      color: var(--g500);
      font-weight: 500;
    }

    /* ===== TRUST BADGES ===== */
    .badges-row {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 8px;
      padding: 20px 16px;
    }
    .bi { display: flex; flex-direction: column; align-items: center; gap: 4px; text-align: center; }
    .bi .bi-i { font-size: 26px; }
    .bi span { font-size: 9px; color: var(--g500); font-weight: 600; text-transform: uppercase; letter-spacing: 0.3px; }

    /* ===== DESC ===== */
    .desc-block {
      padding: 24px 16px 4px;
      font-size: 14px;
      color: var(--g600);
      line-height: 1.7;
    }
    .desc-block p { margin-bottom: 16px; }

    /* ===== VIDEO ===== */
    .vid-section { padding: 0; max-height: 500px; overflow: hidden; }
    .vid-section video { width: 100%; display: block; max-height: 500px; object-fit: cover; }

    /* ===== INFOGRAPHICS ===== */
    .infographics { padding: 0; }
    .infographics img { width: 100%; display: block; }

    /* ===== COMPARE ===== */
    .compare-section { padding: 32px 16px; }
    .s-title { font-size: 20px; font-weight: 800; text-align: center; color: var(--black); margin-bottom: 4px; }
    .s-sub { text-align: center; font-size: 13px; color: var(--g500); margin-bottom: 20px; }
    .cmp-tbl {
      width: 100%;
      border-collapse: separate;
      border-spacing: 0;
      font-size: 13px;
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 1px 8px rgba(0,0,0,0.05);
      table-layout: fixed;
    }
    .cmp-tbl th {
      background: var(--black);
      color: var(--white);
      padding: 12px 8px;
      text-align: center;
      font-weight: 600;
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 0.3px;
      word-break: break-word;
    }
    .cmp-tbl th:first-child { text-align: left; width: 42%; }
    .cmp-tbl td {
      padding: 10px 8px;
      border-bottom: 1px solid var(--g100);
      text-align: center;
      font-size: 11px;
      color: var(--g600);
      background: var(--white);
      word-break: break-word;
    }
    .cmp-tbl td:first-child { text-align: left; font-weight: 500; color: var(--g700); }
    .cmp-tbl tr:last-child td { border-bottom: none; }
    .tc { color: var(--green); font-size: 18px; font-weight: 700; }
    .tx { color: var(--red); font-size: 18px; }

    /* ===== WARRANTY ===== */
    .warranty {
      padding: 36px 16px;
      text-align: center;
      background: var(--green-light);
    }
    .warranty .wi { font-size: 52px; margin-bottom: 12px; }
    .warranty h2 { font-size: 22px; font-weight: 800; margin-bottom: 8px; color: var(--black); }
    .warranty p { font-size: 14px; color: var(--g600); max-width: 480px; margin: 0 auto; line-height: 1.6; }

    /* ===== ACCORDION ===== */
    .acc-section { padding: 24px 16px; }
    .acc { border-bottom: 1px solid var(--g200); }
    .acc-head {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 16px 0;
      cursor: pointer;
      user-select: none;
      -webkit-tap-highlight-color: transparent;
    }
    .acc-head h3 { font-size: 13px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; color: var(--black); }
    .acc-ic {
      width: 24px; height: 24px;
      display: flex; align-items: center; justify-content: center;
      font-size: 20px; color: var(--g400);
      transition: transform 0.3s; font-weight: 300;
    }
    .acc-body { max-height: 0; overflow: hidden; transition: max-height 0.35s ease; }
    .acc.open .acc-body { max-height: 800px; }
    .acc.open .acc-ic { transform: rotate(45deg); }
    .acc-in { padding: 0 0 16px; font-size: 14px; color: var(--g600); line-height: 1.7; }
    .acc-in ul { list-style: none; padding: 0; }
    .acc-in ul li { padding: 4px 0 4px 18px; position: relative; }
    .acc-in ul li::before { content: '•'; position: absolute; left: 0; color: var(--black); font-weight: 700; }
    .acc-in ol { padding-left: 20px; }
    .acc-in ol li { padding: 4px 0; }
    .fq { font-weight: 600; color: var(--black); margin-bottom: 2px; }
    .fa { color: var(--g500); margin-bottom: 12px; }

    /* ===== CROSS-SELL ===== */
    .xsell { padding: 28px 16px; background: var(--g50); }
    .xsell h2 { font-size: 18px; font-weight: 800; text-align: center; margin-bottom: 16px; color: var(--black); }
    .xsell-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; }
    .xc { background: var(--white); border-radius: 12px; overflow: hidden; box-shadow: 0 1px 6px rgba(0,0,0,0.04); transition: transform 0.2s; }
    .xc:active { transform: scale(0.98); }
    .xc-img { aspect-ratio: 1; overflow: hidden; background: var(--g100); }
    .xc-img img { width: 100%; height: 100%; object-fit: cover; }
    .xc-info { padding: 10px 12px; }
    .xc-info .xn { font-size: 11px; font-weight: 600; color: var(--black); line-height: 1.3; margin-bottom: 6px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .xc-info .xp { display: flex; align-items: baseline; gap: 6px; }
    .xc-info .xpn { font-size: 14px; font-weight: 800; color: var(--black); }
    .xc-info .xpw { font-size: 11px; color: var(--g400); text-decoration: line-through; }

    /* ===== REVIEWS ===== */
    .reviews { padding: 32px 16px; }
    .rv-head { text-align: center; margin-bottom: 24px; }
    .rv-head .rv-s { color: var(--gold); font-size: 22px; letter-spacing: 2px; }
    .rv-head .rv-sc { font-size: 32px; font-weight: 800; color: var(--black); margin: 4px 0 2px; }
    .rv-head .rv-ct { font-size: 13px; color: var(--g500); }
    .rv-list { display: flex; flex-direction: column; gap: 14px; }
    .rv {
      background: var(--white);
      border: 1px solid var(--g200);
      border-radius: 14px;
      padding: 16px;
    }
    .rv-top { display: flex; align-items: center; gap: 12px; margin-bottom: 8px; }
    .rv-av { width: 44px; height: 44px; border-radius: 50%; object-fit: cover; flex-shrink: 0; }
    .rv-mt { flex: 1; }
    .rv-nm { font-size: 14px; font-weight: 600; color: var(--black); }
    .rv-vf { font-size: 11px; color: var(--green); font-weight: 600; margin-left: 4px; }
    .rv-dt { font-size: 11px; color: var(--g400); }
    .rv-st { color: var(--gold); font-size: 13px; letter-spacing: 1px; margin-bottom: 6px; }
    .rv-tx { font-size: 13px; color: var(--g600); line-height: 1.5; }
    .rv-ph { margin-top: 10px; border-radius: 10px; overflow: hidden; max-width: min(200px, 60%); }
    .rv-ph img { width: 100%; border-radius: 10px; aspect-ratio: 3/4; object-fit: cover; }

    /* ===== SEPARATOR ===== */
    .sep { height: 1px; background: var(--g200); }

    /* ===== FLOATING CTA ===== */
    .float-cta {
      position: fixed;
      bottom: 0; left: 0; right: 0;
      background: var(--white);
      padding: 10px 16px;
      padding-bottom: calc(10px + env(safe-area-inset-bottom, 0px));
      box-shadow: 0 -3px 16px rgba(0,0,0,0.1);
      z-index: 999;
      display: flex;
      align-items: center;
      gap: 12px;
      transition: transform 0.3s ease;
    }
    .fl-info { flex: 1; }
    .fl-pr { font-size: 20px; font-weight: 800; color: var(--black); }
    .fl-ws { font-size: 12px; color: var(--g400); text-decoration: line-through; }
    .fl-btn {
      background: var(--black);
      color: var(--white);
      padding: 14px 28px;
      border-radius: 12px;
      font-size: 14px;
      font-weight: 700;
      white-space: nowrap;
      transition: all 0.2s;
      position: relative;
      overflow: hidden;
    }
    .fl-btn:active { transform: scale(0.96); }
    .fl-btn .sh {
      position: absolute;
      top: 0; left: -100%;
      width: 100%; height: 100%;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.12), transparent);
      animation: shimmer 2.5s infinite;
    }

    /* ===== FOOTER ===== */
    .footer {
      background: var(--g900);
      color: var(--white);
      padding: 32px 16px 100px;
      text-align: center;
    }
    .footer-links { display: flex; flex-direction: column; gap: 10px; margin-bottom: 24px; }
    .footer-links a { font-size: 13px; color: var(--g400); transition: color 0.2s; }
    .footer-links a:hover { color: var(--white); }
    .footer-pay { display: flex; justify-content: center; gap: 6px; flex-wrap: wrap; margin-bottom: 20px; }
    .pi { background: var(--g800); padding: 5px 10px; border-radius: 4px; font-size: 10px; color: var(--g400); font-weight: 600; }
    .footer-cp { font-size: 12px; color: var(--g600); }

    /* ===== DESKTOP ===== */
    @media (min-width: 768px) {
      .product-layout {
        display: grid;
        grid-template-columns: 50% 50%;
        gap: 40px;
        max-width: 1200px;
        margin: 0 auto;
        padding: 32px 32px;
        align-items: start;
      }
      .gallery-wrap { border-radius: 16px; overflow: hidden; }
      .gallery-slide img, .gallery-slide video { max-height: 520px; }
      .gallery-thumbs { padding: 10px 0; }
      .gallery-dots { display: none; }
      .product-info { padding: 0; }
      .product-title { font-size: 26px; }
      .benefits { padding: 0 0 20px; }
      .pricing-section { padding: 40px 24px; }
      .pricing-cards { flex-direction: row; justify-content: center; }
      .price-card { flex: 1; max-width: 340px; }
      .rv-list { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; }
      .infographics { max-width: 900px; margin: 0 auto; }
      .compare-section { max-width: 700px; margin: 0 auto; }
      .acc-section { max-width: 700px; margin: 0 auto; padding: 40px 24px; }
      .xsell { max-width: 800px; margin: 0 auto; padding: 40px 24px; }
      .xsell-grid { grid-template-columns: repeat(3, 1fr); }
      .vid-section { max-width: 900px; margin: 0 auto; }
      .float-cta { display: none; }
      .footer { padding-bottom: 40px; }
    }
    @media (min-width: 1024px) {
      .rv-list { grid-template-columns: repeat(3, 1fr); }
      .pricing-cards { gap: 20px; }
    }
    @media (max-width: 767px) {
      .footer { padding-bottom: calc(90px + env(safe-area-inset-bottom, 0px)); }
    }

    /* ===== TELAS MUITO PEQUENAS (320-380px) ===== */
    @media (max-width: 380px) {
      .topbar { font-size: 11px; padding: 8px 12px; }
      .gallery-slide img, .gallery-slide video { max-height: 55vh; }
      .gallery-nav { width: 32px; height: 32px; font-size: 14px; }
      .gallery-thumb { min-width: 44px; width: 44px; height: 44px; }
      .product-title { font-size: 17px; }
      .product-desc { font-size: 13px; }
      .benefits li { font-size: 13px; padding: 7px 10px; }
      .pricing-header h2 { font-size: 18px; }
      .price-card { padding: 14px 10px 14px 42px; }
      .price-card .c-name { font-size: 14px; }
      .price-card .p-now { font-size: 20px; }
      .price-card .p-was { font-size: 12px; }
      .price-card .radio { left: 12px; }
      .xsell-grid { grid-template-columns: 1fr; max-width: 280px; margin: 0 auto; }
      .cta-btn { font-size: 14px; padding: 14px; }
      .fl-pr { font-size: 17px; }
      .fl-btn { padding: 12px 20px; font-size: 13px; }
      .rv-av { width: 38px; height: 38px; }
      .rv-nm { font-size: 13px; }
      .rv-tx { font-size: 12px; }
      .cmp-tbl th { font-size: 9px; padding: 10px 6px; }
      .cmp-tbl td { font-size: 10px; padding: 8px 6px; }
      .warranty h2 { font-size: 19px; }
      .warranty p { font-size: 13px; }
      .s-title { font-size: 18px; }
