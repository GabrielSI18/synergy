---
// Bettdow AirLux Pro - Landing Page (Clone fiel do original)
---

<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>Bettdow AirLux Pro - Secador de Alta Velocidade com Íons Negativos, 1500W, 110.000 rpm | Mercado Pago</title>
  <meta name="description" content="Secador de cabelo profissional Bettdow AirLux Pro com motor digital de 110.000 rpm, tecnologia de íons negativos, 1500W. Compre com segurança pelo Mercado Pago.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet">
  <style is:global>
    :root {
      --black: #121212;
      --white: #ffffff;
      --g50: #fafafa;
      --g100: #f5f5f5;
      --g200: #e5e5e5;
      --g300: #d4d4d4;
      --g400: #a3a3a3;
      --g500: #737373;
      --g600: #525252;
      --g700: #404040;
      --g800: #262626;
      --g900: #171717;
      --green: #16a34a;
      --green-light: #dcfae6;
      --red: #ef4444;
      --gold: #f6b700;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; overflow-x: hidden; }

    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      line-height: 1.6;
      color: var(--black);
      background: var(--white);
      overflow-x: hidden;
      max-width: 100vw;
      -webkit-font-smoothing: antialiased;
      -webkit-text-size-adjust: 100%;
    }

    img, video { max-width: 100%; height: auto; display: block; }
    a { text-decoration: none; color: inherit; }
    button { cursor: pointer; border: none; font-family: inherit; }

    /* ===== TOPBAR ===== */
    .topbar {
      background: var(--black);
      color: var(--white);
      text-align: center;
      padding: 10px 16px;
      font-size: 13px;
      font-weight: 500;
      letter-spacing: 0.3px;
      line-height: 1.4;
    }
    .topbar span { color: #f0c040; font-weight: 700; }

    /* ===== HEADER ===== */
    .header {
      background: var(--white);
      padding: 14px 16px;
      border-bottom: 1px solid var(--g200);
      position: sticky;
      top: 0;
      z-index: 100;
    }
    .header-inner {
      max-width: 1200px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .logo {
      display: flex;
      align-items: center;
    }

    /* ===== GALLERY ===== */
    .gallery-area { position: relative; width: 100%; overflow: hidden; }
    .gallery-wrap {
      position: relative;
      width: 100%;
      overflow: hidden;
      background: var(--white);
    }
    .gallery-slider {
      display: flex;
      width: 100%;
      overflow-x: scroll;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }
    .gallery-slider::-webkit-scrollbar { display: none; }
    .gallery-slide {
      flex: 0 0 100%;
      scroll-snap-align: start;
      background: var(--white);
      aspect-ratio: 1 / 1;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }
    .gallery-slide img, .gallery-slide video {
      width: 100%;
      height: 100%;
      object-fit: contain;
      display: block;
    }
    .gallery-nav {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      width: 40px;
      height: 40px;
      background: rgba(255,255,255,0.92);
      border: none;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 18px;
      color: var(--g700);
      z-index: 10;
      box-shadow: 0 2px 12px rgba(0,0,0,0.1);
      transition: all 0.2s;
    }
    .gallery-nav:active { transform: translateY(-50%) scale(0.92); }
    .gallery-nav.prev { left: 8px; }
    .gallery-nav.next { right: 8px; }
    .gallery-dots {
      display: flex;
      justify-content: center;
      gap: 6px;
      padding: 10px 0;
      background: var(--white);
    }
    .gallery-dot {
      width: 8px; height: 8px;
      border-radius: 50%;
      background: var(--g300);
      transition: all 0.25s;
      cursor: pointer;
    }
    .gallery-dot.active {
      background: var(--black);
      width: 24px;
      border-radius: 4px;
    }
    .gallery-thumbs {
      display: flex;
      gap: 6px;
      padding: 6px 12px 10px;
      overflow-x: auto;
      scrollbar-width: none;
      background: var(--white);
    }
    .gallery-thumbs::-webkit-scrollbar { display: none; }
    .gallery-thumb {
      min-width: 48px; width: 48px; height: 48px;
      border-radius: 6px;
      overflow: hidden;
      border: 2px solid transparent;
      cursor: pointer;
      flex-shrink: 0;
      transition: all 0.2s;
      opacity: 0.5;
    }
    .gallery-thumb.active { border-color: var(--black); opacity: 1; }
    .gallery-thumb img { width: 100%; height: 100%; object-fit: cover; }
    .gallery-thumb.is-video { position: relative; }
    .gallery-thumb.is-video::after {
      content: '\25B6';
      position: absolute;
      top: 50%; left: 50%;
      transform: translate(-50%, -50%);
      font-size: 12px;
      color: white;
      text-shadow: 0 1px 3px rgba(0,0,0,0.6);
    }

    /* ===== PRODUCT INFO ===== */
    .product-info { padding: 24px 20px 8px; }

    /* Rating component */
    .rating {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 14px;
      justify-content: center;
    }
    .rating .stars-r {
      font-size: 17px;
      letter-spacing: 2px;
      background: linear-gradient(90deg, #000 96%, #e6e6e6 96%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .rating .meta {
      font-size: 14px;
      color: #555;
    }

    .product-title {
      font-size: 22px;
      font-weight: 800;
      line-height: 1.3;
      color: var(--black);
      margin-bottom: 16px;
      text-align: center;
      letter-spacing: -0.3px;
    }

    /* Highlight box */
    .highlight-box {
      background: #f8f8f8;
      border-left: 4px solid var(--black);
      border-radius: 0 8px 8px 0;
      padding: 14px 16px;
      margin: 0 0 1.5rem 0;
      font-size: 1.05rem;
      line-height: 1.6;
      color: var(--black);
      text-align: left;
    }

    /* ===== BENEFITS ===== */
    .benefits-list {
      padding: 0 16px;
      margin: 1.5rem 0;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }
    .benefit-item {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      font-size: 0.95rem;
      line-height: 1.6;
      color: var(--black);
    }
    .benefit-item .material-symbols-outlined {
      font-size: 20px;
      color: var(--black);
      flex-shrink: 0;
      margin-top: 2px;
    }

    /* ===== PRICING ===== */
    .pricing-section {
      padding: 0 16px;
      margin: 24px 0 16px;
    }
    .pricing-header {
      margin-bottom: 12px;
    }
    .pricing-header h2 {
      font-size: 14px;
      font-weight: 700;
      color: var(--black);
    }
    .pricing-cards {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }
    .price-card {
      background: #ededed;
      border: 2px solid transparent;
      border-radius: 8px;
      padding: 14px 14px 14px 52px;
      position: relative;
      transition: all 0.25s;
      cursor: pointer;
    }
    .price-card.selected {
      background: var(--white);
      border-color: var(--black);
    }
    .price-card .bdg {
      position: absolute;
      top: -11px;
      right: 16px;
      padding: 4px 12px;
      border-radius: 4px;
      font-size: 11px;
      font-weight: 700;
      color: white;
      background: var(--black);
    }
    .price-card .c-top {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 2px;
    }
    .price-card .c-name {
      font-size: 20px;
      font-weight: 700;
      color: var(--black);
    }
    .price-card .c-eco {
      font-size: 12px;
      font-weight: 500;
      color: #555;
      margin-bottom: 4px;
    }
    .price-card .c-desc {
      font-size: 14px;
      color: #555;
      margin-bottom: 4px;
    }
    .price-card .c-prices {
      display: flex;
      align-items: baseline;
      gap: 10px;
    }
    .price-card .p-now {
      font-size: 22px;
      font-weight: 800;
      color: var(--black);
    }
    .price-card .p-was {
      font-size: 14px;
      color: #555;
      text-decoration: line-through;
    }
    .price-card .c-gift {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-top: 8px;
      padding: 8px;
      background: #b3b3b3;
      border-radius: 6px;
      font-size: 13px;
      font-weight: 700;
      color: var(--black);
    }
    .price-card .c-gift img {
      width: 30px;
      height: 30px;
      border-radius: 4px;
      object-fit: cover;
    }
    .price-card .radio {
      position: absolute;
      left: 16px;
      top: 22px;
      width: 22px; height: 22px;
      border-radius: 50%;
      border: 2px solid var(--g300);
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.2s;
      background: var(--white);
    }
    .price-card.selected .radio { border-color: var(--black); }
    .price-card.selected .radio::after {
      content: '';
      width: 12px; height: 12px;
      border-radius: 50%;
      background: var(--black);
    }

    /* ===== CTA BUTTON ===== */
    .cta-wrap { padding: 16px 16px; }
    .cta-btn {
      display: block;
      width: 100%;
      padding: 18px;
      background: var(--black);
      color: var(--white);
      text-align: center;
      font-size: 18px;
      font-weight: 700;
      border-radius: 8px;
      letter-spacing: 0.3px;
      transition: all 0.2s;
      position: relative;
      overflow: hidden;
    }
    .cta-btn:hover { background: var(--g800); }
    .cta-btn:active { transform: scale(0.98); }
    .cta-btn .sh {
      position: absolute;
      top: 0; left: -100%;
      width: 100%; height: 100%;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.15), transparent);
      animation: shimmer 2.5s infinite;
    }
    @keyframes shimmer { 100% { left: 100%; } }

    .cta-trust {
      display: flex;
      justify-content: center;
      gap: 16px;
      margin-top: 14px;
      flex-wrap: wrap;
    }
    .cta-trust-item {
      display: flex;
      align-items: center;
      gap: 4px;
      font-size: 12px;
      color: var(--g500);
      font-weight: 500;
    }
    .cta-trust-item .material-symbols-outlined {
      font-size: 16px;
    }

    /* ===== BADGES (Frete + Garantia) ===== */
    .trust-badges {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.5em;
      padding: 0 16px;
      margin: 1.2rem 0;
    }
    .trust-badge {
      display: flex;
      align-items: center;
      gap: 0.5em;
      background: #f3f3f3;
      border-radius: 0.4em;
      padding: 0.5em 0.6em;
      font-size: 0.85rem;
      color: var(--black);
      font-weight: 500;
      line-height: 1.3;
    }
    .trust-badge .material-symbols-outlined {
      font-size: 1.2em;
      color: var(--black);
      flex-shrink: 0;
    }

    /* ===== DUAL VIDEO ===== */
    .dual-video {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
      padding: 0 16px;
      max-width: 1200px;
      margin: 0 auto 32px;
    }
    .dv-video {
      width: 100%;
      height: auto;
      aspect-ratio: 9/16;
      object-fit: cover;
      border-radius: 12px;
      display: block;
      background: #f5f5f5;
      box-shadow: 0 6px 20px rgba(0,0,0,0.08);
    }

    /* ===== DESC ===== */
    .desc-block {
      padding: 32px 24px 8px;
      font-size: 15px;
      color: var(--g600);
      line-height: 1.8;
      max-width: 720px;
      margin: 0 auto;
      text-align: center;
    }
    .desc-block p { margin-bottom: 18px; }
    .desc-block p:last-child { margin-bottom: 0; }

    /* ===== INFOGRAPHICS ===== */
    .info-grid {
      padding: 16px;
      display: grid;
      grid-template-columns: 1fr;
      gap: 12px;
      max-width: 1000px;
      margin: 0 auto;
    }
    .info-grid img, .info-grid video {
      width: 100%;
      display: block;
      border-radius: 12px;
    }

    /* ===== TRUST ROW (4 icons) ===== */
    .badges-row {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 8px;
      padding: 20px 16px;
    }
    .bi { display: flex; flex-direction: column; align-items: center; gap: 4px; text-align: center; }
    .bi .bi-i { font-size: 26px; }
    .bi span { font-size: 9px; color: var(--g500); font-weight: 600; text-transform: uppercase; letter-spacing: 0.3px; }

    /* ===== COMPARE ===== */
    .compare-section { padding: 32px 16px; }
    .s-title { font-size: 22px; font-weight: 800; text-align: center; color: var(--black); margin-bottom: 4px; }
    .s-sub { text-align: center; font-size: 14px; color: var(--g500); margin-bottom: 20px; }
    .cmp-tbl {
      width: 100%;
      border-collapse: separate;
      border-spacing: 0;
      font-size: 14px;
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 1px 8px rgba(0,0,0,0.05);
      table-layout: fixed;
    }
    .cmp-tbl th {
      background: var(--black);
      color: var(--white);
      padding: 12px 8px;
      text-align: center;
      font-weight: 600;
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.3px;
      word-break: break-word;
    }
    .cmp-tbl th:first-child { text-align: left; width: 42%; }
    .cmp-tbl td {
      padding: 10px 8px;
      border-bottom: 1px solid var(--g100);
      text-align: center;
      font-size: 13px;
      color: var(--g600);
      background: var(--white);
      word-break: break-word;
    }
    .cmp-tbl td:first-child { text-align: left; font-weight: 500; color: var(--g700); }
    .cmp-tbl tr:last-child td { border-bottom: none; }
    .tc { color: var(--green); font-size: 18px; font-weight: 700; }
    .tx { color: var(--red); font-size: 18px; }

    /* ===== WARRANTY ===== */
    .warranty {
      padding: 36px 16px;
      text-align: center;
      background: var(--green-light);
    }
    .warranty .wi { font-size: 52px; margin-bottom: 12px; color: var(--green); }
    .warranty .wi .material-symbols-outlined { font-size: 52px; }
    .warranty h2 { font-size: 24px; font-weight: 800; margin-bottom: 8px; color: var(--black); }
    .warranty p { font-size: 15px; color: var(--g600); max-width: 480px; margin: 0 auto; line-height: 1.6; }

    /* ===== ACCORDION ===== */
    .accordion {
      width: 100%;
      max-width: 850px;
      margin: 0 auto;
      padding: 0 16px;
    }
    .accordion-item {
      border-bottom: 1px solid #e5e5e5;
    }
    .accordion-header {
      width: 100%;
      padding: 18px 0;
      background: none;
      border: none;
      text-align: left;
      font-size: 14px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1px;
      cursor: pointer;
      display: flex;
      justify-content: space-between;
      align-items: center;
      color: var(--black);
      font-family: inherit;
    }
    .accordion-header::after {
      content: "+";
      font-size: 22px;
      font-weight: 300;
      transition: transform 0.3s;
    }
    .accordion-item.active .accordion-header::after {
      content: "\2212";
    }
    .accordion-content {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.3s ease;
      font-size: 15px;
      color: var(--g600);
      line-height: 1.7;
    }
    .accordion-item.active .accordion-content {
      padding: 12px 0 20px;
    }

    /* ===== CROSS-SELL ===== */
    .xsell { padding: 28px 16px; background: var(--g50); }
    .xsell h2 { font-size: 20px; font-weight: 800; text-align: center; margin-bottom: 4px; color: var(--black); }
    .xsell-sub { font-size: 13px; color: var(--g400); text-align: center; margin-bottom: 16px; }
    .xsell-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; }
    .xc { background: var(--white); border-radius: 12px; overflow: hidden; box-shadow: 0 1px 6px rgba(0,0,0,0.04); transition: transform 0.2s, box-shadow 0.2s; cursor: pointer; position: relative; }
    .xc:hover { transform: translateY(-2px); box-shadow: 0 6px 18px rgba(0,0,0,0.10); }
    .xc:active { transform: scale(0.98); }
    .xc-badge { position: absolute; top: 8px; left: 8px; font-size: 10px; font-weight: 700; padding: 3px 8px; border-radius: 20px; z-index: 1; text-transform: uppercase; letter-spacing: 0.3px; }
    .xc-badge.gift { background: #16a34a; color: #fff; }
    .xc-badge.bundle { background: #1d4ed8; color: #fff; }
    .xc-img { aspect-ratio: 1; overflow: hidden; background: var(--g100); }
    .xc-img img { width: 100%; height: 100%; object-fit: cover; }
    .xc-info { padding: 10px 12px; }
    .xc-info .xn { font-size: 12px; font-weight: 600; color: var(--black); line-height: 1.3; margin-bottom: 6px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .xc-info .xp { display: flex; align-items: baseline; gap: 6px; }
    .xc-info .xpn { font-size: 15px; font-weight: 800; color: var(--black); }
    .xc-info .xpw { font-size: 12px; color: var(--g400); text-decoration: line-through; }
    .xc-cta { display: block; margin: 8px 12px 10px; background: var(--black); color: var(--white); font-size: 11px; font-weight: 700; text-align: center; padding: 7px 0; border-radius: 8px; letter-spacing: 0.2px; }

    /* ===== REVIEWS ===== */
    .reviews-wrapper {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 12px;
    }
    .reviews-header {
      display: flex;
      align-items: center;
      gap: 10px;
      margin: 18px 0;
    }
    .reviews-stars {
      color: #000;
      font-size: 18px;
      letter-spacing: 1px;
    }
    .reviews-score {
      font-size: 16px;
      color: #333;
    }
    .reviews-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }
    .review-card {
      background: #fff;
      border: 1px solid #eee;
      border-radius: 12px;
      padding: 12px;
      box-shadow: 0 3px 10px rgba(0,0,0,0.04);
      display: flex;
      flex-direction: column;
      height: 100%;
    }
    .review-img {
      width: 100%;
      height: 200px;
      object-fit: cover;
      border-radius: 8px;
      margin-bottom: 10px;
    }
    .review-name {
      font-weight: 600;
      margin: 4px 0 2px;
      font-size: 15px;
    }
    .verified {
      color: #16a34a;
      font-weight: 600;
      font-size: 13px;
      margin-left: 8px;
    }
    .review-date {
      color: #777;
      font-size: 13px;
      margin-bottom: 8px;
    }
    .review-stars {
      color: #f6b700;
      font-size: 16px;
      margin-bottom: 8px;
    }
    .review-text {
      color: #444;
      font-size: 14px;
      line-height: 1.45;
      margin-top: auto;
    }
    .reviews-pagination {
      margin-top: 18px;
      display: flex;
      justify-content: center;
      width: 100%;
      overflow: hidden;
    }
    .pages-inner {
      display: flex;
      gap: 8px;
      padding: 6px;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }
    .pages-inner::-webkit-scrollbar { display: none; }
    .page-btn {
      flex: 0 0 auto;
      padding: 8px 12px;
      border: 1px solid #ddd;
      border-radius: 8px;
      font-size: 14px;
      color: #333;
      background: #fff;
      cursor: pointer;
      font-family: inherit;
    }
    .page-btn.current {
      background: #000;
      color: #fff;
      border-color: #000;
      font-weight: 600;
    }

    /* ===== SEPARATOR ===== */
    .sep { height: 1px; background: var(--g200); }

    /* ===== FLOATING CTA ===== */
    .float-cta {
      position: fixed;
      bottom: 0; left: 0; right: 0;
      background: var(--white);
      padding: 10px 16px;
      padding-bottom: calc(10px + env(safe-area-inset-bottom, 0px));
      box-shadow: 0 -3px 16px rgba(0,0,0,0.1);
      z-index: 999;
      display: flex;
      align-items: center;
      gap: 12px;
      transition: transform 0.3s ease;
    }
    .fl-info { flex: 1; }
    .fl-pr { font-size: 20px; font-weight: 800; color: var(--black); }
    .fl-ws { font-size: 12px; color: var(--g400); text-decoration: line-through; }
    .fl-btn {
      background: var(--black);
      color: var(--white);
      padding: 14px 28px;
      border-radius: 8px;
      font-size: 14px;
