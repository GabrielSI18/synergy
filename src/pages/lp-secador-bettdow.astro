      <div class="fl-ws" id="flWs">R$ 756,00</div>
    </div>
    <button class="fl-btn" onclick="goOffers()"><span class="sh"></span>COMPRAR AGORA</button>
  </div>

  <script>
    // ===== GALLERY =====
    var slides = [
      { type: 'image', src: 'https://madeliebrasil.com/cdn/shop/files/br-11134207-7r98o-m82v867w1gk111.jpg?v=1764562749&width=1000', thumb: 'https://madeliebrasil.com/cdn/shop/files/br-11134207-7r98o-m82v867w1gk111.jpg?v=1764562749&width=150', alt: 'Branco' },
      { type: 'image', src: 'https://madeliebrasil.com/cdn/shop/files/br-11134207-7r98o-m82v867w2v4h0d.jpg?v=1764562749&width=1000', thumb: 'https://madeliebrasil.com/cdn/shop/files/br-11134207-7r98o-m82v867w2v4h0d.jpg?v=1764562749&width=150', alt: 'Azul' },
      { type: 'image', src: 'https://madeliebrasil.com/cdn/shop/files/br-11134207-7r98o-mdo9os98lqdtaf.jpg?v=1764562749&width=1000', thumb: 'https://madeliebrasil.com/cdn/shop/files/br-11134207-7r98o-mdo9os98lqdtaf.jpg?v=1764562749&width=150', alt: 'Rosa' },
      { type: 'image', src: 'https://madeliebrasil.com/cdn/shop/files/br-11134207-7r98o-mdo9os98n4y988.jpg?v=1764562750&width=1000', thumb: 'https://madeliebrasil.com/cdn/shop/files/br-11134207-7r98o-mdo9os98n4y988.jpg?v=1764562750&width=150', alt: 'Roxo' },
      { type: 'video', src: 'https://cdn.shopify.com/videos/c/o/v/23d17c1bfa954fb09d854cdbce308f03.mp4', thumb: 'https://madeliebrasil.com/cdn/shop/files/br-11134207-7r98o-m82v867w1gk111.jpg?v=1764562749&width=150', alt: 'Vídeo' },
    ];

    var cur = 0;
    var sliderEl = document.getElementById('gallerySlider');
    var dotsEl = document.getElementById('galleryDots');
    var thumbsEl = document.getElementById('galleryThumbs');

    slides.forEach(function(s, i) {
      var d = document.createElement('div');
      d.className = 'gallery-slide';
      if (s.type === 'video') {
        d.innerHTML = '<video autoplay loop muted playsinline><source src="' + s.src + '" type="video/mp4"></video>';
      } else {
        d.innerHTML = '<img src="' + s.src + '" alt="' + s.alt + '">';
      }
      sliderEl.appendChild(d);

      var dot = document.createElement('div');
      dot.className = 'gallery-dot' + (i === 0 ? ' active' : '');
      dot.onclick = function() { goTo(i); };
      dotsEl.appendChild(dot);

      var th = document.createElement('div');
      th.className = 'gallery-thumb' + (i === 0 ? ' active' : '') + (s.type === 'video' ? ' is-video' : '');
      th.innerHTML = '<img src="' + s.thumb + '" alt="' + s.alt + '">';
      th.onclick = function() { goTo(i); };
      thumbsEl.appendChild(th);
    });

    function goTo(i) {
      cur = i;
      sliderEl.style.transform = 'translateX(-' + (i * 100) + '%)';
      document.querySelectorAll('.gallery-dot').forEach(function(d, j) { d.classList.toggle('active', j === i); });
      document.querySelectorAll('.gallery-thumb').forEach(function(t, j) { t.classList.toggle('active', j === i); });
      sliderEl.querySelectorAll('video').forEach(function(v, j) { j === i ? v.play() : v.pause(); });
    }

    document.getElementById('prevBtn').onclick = function() { goTo(cur > 0 ? cur - 1 : slides.length - 1); };
    document.getElementById('nextBtn').onclick = function() { goTo(cur < slides.length - 1 ? cur + 1 : 0); };

    // Touch swipe
    var tx = 0;
    var gw = document.getElementById('galleryWrap');
    gw.addEventListener('touchstart', function(e) { tx = e.changedTouches[0].screenX; }, { passive: true });
    gw.addEventListener('touchend', function(e) {
      var diff = tx - e.changedTouches[0].screenX;
      if (Math.abs(diff) > 50) {
        diff > 0 ? goTo(cur < slides.length - 1 ? cur + 1 : 0) : goTo(cur > 0 ? cur - 1 : slides.length - 1);
      }
    }, { passive: true });

    // ===== ACCORDION =====
    function toggleAcc(el) { el.parentElement.classList.toggle('open'); }

    // ===== PRICING =====
    document.querySelectorAll('.price-card').forEach(function(card) {
      card.addEventListener('click', function() {
        document.querySelectorAll('.price-card').forEach(function(c) { c.classList.remove('selected'); });
        card.classList.add('selected');
        document.getElementById('flPr').textContent = card.dataset.label;
        document.getElementById('flWs').textContent = card.dataset.was;
      });
    });

    // ===== SCROLL TO OFFERS =====
    function goOffers() {
      document.getElementById('ofertas').scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    // ===== FLOAT CTA VISIBILITY =====
    var fc = document.getElementById('floatCta');
    var ps = document.getElementById('ofertas');
    if (window.innerWidth < 768) {
      fc.style.transition = 'transform 0.3s ease';
      var chk = function() {
        var r = ps.getBoundingClientRect();
        fc.style.transform = (r.bottom < 0 || r.top > window.innerHeight) ? 'translateY(0)' : 'translateY(100%)';
      };
      window.addEventListener('scroll', chk, { passive: true });
      chk();
    }
  </script>

