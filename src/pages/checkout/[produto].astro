---
// Página de checkout: /checkout/1-unidade  /checkout/2-unidades  /checkout/kit-profissional
const { produto } = Astro.params;

const PRODUTOS: Record<string, { nome: string; preco: string; parcelas: string; desc: string }> = {
  '1-unidade': {
    nome: 'Secador BettDow AirLux Pro',
    preco: 'R$ 199,90',
    parcelas: '12x R$ 19,72',
    desc: '1 Unidade',
  },
  '2-unidades': {
    nome: 'Secador BettDow AirLux Pro',
    preco: 'R$ 349,90',
    parcelas: '12x R$ 34,57',
    desc: '2 Unidades',
  },
  'kit-profissional': {
    nome: 'Kit Profissional BettDow AirLux Pro',
    preco: 'R$ 249,90',
    parcelas: '12x R$ 24,72',
    desc: 'Kit Profissional + Brinde',
  },
};

const prod = PRODUTOS[produto ?? ''];

// Redireciona para a LP se o produto não existir
if (!prod) {
  return Astro.redirect('/lp-secador-bettdow');
}
---

<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Checkout Seguro — {prod.nome}</title>
  <meta name="robots" content="noindex, nofollow">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background: #f0f2f5;
      color: #1a1a2e;
      min-height: 100vh;
    }

    /* ── HEADER ── */
    .ck-header {
      background: #fff;
      border-bottom: 1px solid #e8e8e8;
      padding: 14px 20px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: sticky;
      top: 0;
      z-index: 10;
    }
    .ck-logo { font-weight: 800; font-size: 1.2rem; color: #2563eb; letter-spacing: -0.5px; }
    .ck-secure {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 0.78rem;
      color: #16a34a;
      font-weight: 600;
    }
    .ck-secure svg { flex-shrink: 0; }

    /* ── LAYOUT ── */
    .ck-wrap {
      max-width: 860px;
      margin: 0 auto;
      padding: 24px 16px 60px;
      display: grid;
      grid-template-columns: 1fr 360px;
      gap: 24px;
      align-items: start;
    }
    @media (max-width: 700px) {
      .ck-wrap { grid-template-columns: 1fr; }
      .ck-side { order: -1; }
    }

    /* ── CARD PRODUTO (lateral) ── */
    .ck-side {
      background: #fff;
      border-radius: 14px;
      padding: 20px;
      border: 1px solid #e8e8e8;
      position: sticky;
      top: 72px;
    }
    .ck-prod-badge {
      background: #eff6ff;
      color: #2563eb;
      font-size: 0.72rem;
      font-weight: 700;
      padding: 3px 10px;
      border-radius: 20px;
      display: inline-block;
      margin-bottom: 10px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    .ck-prod-nome { font-size: 1rem; font-weight: 700; margin-bottom: 2px; }
    .ck-prod-desc { font-size: 0.82rem; color: #64748b; margin-bottom: 14px; }
    .ck-prod-preco {
      font-size: 1.5rem;
      font-weight: 800;
      color: #16a34a;
    }
    .ck-prod-parc { font-size: 0.82rem; color: #64748b; margin-top: 2px; }
    .ck-divider { border: none; border-top: 1px solid #f0f0f0; margin: 16px 0; }
    .ck-garantia {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      background: #f0fdf4;
      border-radius: 10px;
      padding: 12px;
      font-size: 0.8rem;
      color: #15803d;
    }
    .ck-garantia svg { flex-shrink: 0; margin-top: 1px; }
    .ck-bandeiras {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      margin-top: 14px;
    }
    .ck-bandeiras span {
      background: #f8fafc;
      border: 1px solid #e2e8f0;
      border-radius: 6px;
      padding: 4px 10px;
      font-size: 0.72rem;
      font-weight: 600;
      color: #475569;
    }

    /* ── FORMULÁRIO ── */
    .ck-form-card {
      background: #fff;
      border-radius: 14px;
      padding: 28px 24px;
      border: 1px solid #e8e8e8;
    }
    .ck-step-title {
      font-size: 1rem;
      font-weight: 700;
      margin-bottom: 18px;
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .ck-step-num {
      width: 26px;
      height: 26px;
      background: #2563eb;
      color: #fff;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.78rem;
      font-weight: 800;
      flex-shrink: 0;
    }

    .ck-field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
    .ck-field { margin-bottom: 14px; }
    .ck-field label {
      display: block;
      font-size: 0.78rem;
      font-weight: 600;
      color: #475569;
      margin-bottom: 5px;
    }
    .ck-field input {
      width: 100%;
      padding: 11px 14px;
      border: 1.5px solid #e2e8f0;
      border-radius: 9px;
      font-size: 0.92rem;
      color: #1a1a2e;
      outline: none;
      transition: border-color 0.2s;
      background: #fff;
    }
    .ck-field input:focus { border-color: #2563eb; }
    .ck-field input.erro { border-color: #ef4444; }
    .msg-erro { font-size: 0.72rem; color: #ef4444; margin-top: 3px; display: none; }

    /* ── TABS PAGAMENTO ── */
    .ck-pay-tabs {
      display: flex;
      gap: 8px;
      margin-bottom: 20px;
    }
    .ck-tab {
      flex: 1;
      padding: 10px;
      border: 2px solid #e2e8f0;
      border-radius: 10px;
      background: #fff;
      cursor: pointer;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 4px;
      font-size: 0.78rem;
      font-weight: 600;
      color: #64748b;
      transition: all 0.2s;
    }
    .ck-tab.ativo {
      border-color: #2563eb;
      background: #eff6ff;
      color: #2563eb;
    }
    .ck-tab svg { width: 22px; height: 22px; }

    /* Painéis por método */
    .ck-panel { display: none; }
    .ck-panel.ativo { display: block; }

    /* PIX panel */
    .ck-pix-info {
      background: #f0fdf4;
      border: 1px solid #bbf7d0;
      border-radius: 10px;
      padding: 14px;
      font-size: 0.85rem;
      color: #15803d;
      display: flex;
      gap: 10px;
      align-items: flex-start;
      margin-bottom: 16px;
    }

    /* ── BOTÃO PAGAR ── */
    .ck-btn-pagar {
      width: 100%;
      padding: 15px;
      background: linear-gradient(135deg, #16a34a, #15803d);
      color: #fff;
      border: none;
      border-radius: 12px;
      font-size: 1.05rem;
      font-weight: 800;
      cursor: pointer;
      margin-top: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      transition: opacity 0.2s, transform 0.15s;
      letter-spacing: 0.3px;
    }
    .ck-btn-pagar:hover { opacity: 0.92; transform: translateY(-1px); }
    .ck-btn-pagar:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }

    /* ── LOADING OVERLAY ── */
    #loadingOverlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.55);
      z-index: 100;
      align-items: center;
      justify-content: center;
      flex-direction: column;
      gap: 16px;
      color: #fff;
      font-weight: 600;
      font-size: 0.95rem;
    }
    #loadingOverlay.show { display: flex; }
    .spinner {
      width: 44px;
      height: 44px;
      border: 4px solid rgba(255,255,255,0.3);
      border-top-color: #fff;
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }

    /* ── MODAL RESULTADO ── */
    #modalResultado {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.55);
      z-index: 200;
      align-items: center;
      justify-content: center;
      padding: 16px;
    }
    #modalResultado.show { display: flex; }
    .modal-box {
      background: #fff;
      border-radius: 18px;
      padding: 32px 28px;
      max-width: 420px;
      width: 100%;
      text-align: center;
    }
    .modal-icon { font-size: 3rem; margin-bottom: 12px; }
    .modal-titulo { font-size: 1.2rem; font-weight: 800; margin-bottom: 8px; }
    .modal-sub { font-size: 0.88rem; color: #64748b; margin-bottom: 20px; }

    /* QR CODE */
    #qrcodeContainer { margin: 16px auto; }
    #qrcodeContainer img { max-width: 200px; border-radius: 10px; border: 1px solid #e2e8f0; }
    .pix-copy-box {
      background: #f8fafc;
      border: 1px solid #e2e8f0;
      border-radius: 10px;
      padding: 10px 14px;
      font-size: 0.75rem;
      word-break: break-all;
      color: #1a1a2e;
      margin-bottom: 12px;
      text-align: left;
      max-height: 80px;
      overflow-y: auto;
    }
    .btn-copiar {
      background: #2563eb;
      color: #fff;
      border: none;
      border-radius: 9px;
      padding: 10px 22px;
      font-weight: 700;
      cursor: pointer;
      font-size: 0.88rem;
    }
    .btn-copiar:hover { opacity: 0.88; }
  </style>
</head>
<body>

  <!-- HEADER -->
  <header class="ck-header">
    <div class="ck-logo">Synergy</div>
    <div class="ck-secure">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
      Compra 100% segura
    </div>
  </header>

  <!-- LOADING OVERLAY -->
  <div id="loadingOverlay">
    <div class="spinner"></div>
    Processando pagamento...
  </div>

  <!-- MODAL RESULTADO -->
  <div id="modalResultado">
    <div class="modal-box" id="modalBox">
      <div class="modal-icon" id="modalIcon">⏳</div>
      <div class="modal-titulo" id="modalTitulo">Aguarde...</div>
      <div class="modal-sub" id="modalSub"></div>
      <!-- QR Code PIX (injetado via JS) -->
      <div id="qrcodeContainer" style="display:none">
        <img id="qrImg" src="" alt="QR Code PIX">
      </div>
      <div id="pixCopyBox" class="pix-copy-box" style="display:none"></div>
      <button class="btn-copiar" id="btnCopiar" style="display:none" onclick="copiarPix()">📋 Copiar código PIX</button>
      <br><br>
      <button onclick="fecharModal()" style="background:none;border:none;color:#64748b;cursor:pointer;font-size:0.85rem;text-decoration:underline;">Fechar</button>
    </div>
  </div>

  <!-- CONTEÚDO -->
  <main class="ck-wrap">

    <!-- FORMULÁRIO -->
    <div>

      <!-- BLOCO 1: Dados pessoais -->
      <div class="ck-form-card" style="margin-bottom:16px">
        <div class="ck-step-title">
          <span class="ck-step-num">1</span>
          Seus dados
        </div>

        <div class="ck-field">
          <label for="nome">Nome completo *</label>
          <input type="text" id="nome" placeholder="João da Silva" autocomplete="name">
          <div class="msg-erro" id="erroNome">Informe seu nome completo.</div>
        </div>

        <div class="ck-field-row">
          <div class="ck-field">
            <label for="email">E-mail *</label>
            <input type="email" id="email" placeholder="joao@email.com" autocomplete="email">
            <div class="msg-erro" id="erroEmail">E-mail inválido.</div>
          </div>
          <div class="ck-field">
            <label for="telefone">Telefone *</label>
            <input type="tel" id="telefone" placeholder="(11) 99999-9999" autocomplete="tel">
            <div class="msg-erro" id="erroTelefone">Informe o telefone.</div>
          </div>
        </div>

        <div class="ck-field">
          <label for="cpf">CPF *</label>
          <input type="text" id="cpf" placeholder="000.000.000-00" maxlength="14" autocomplete="off">
          <div class="msg-erro" id="erroCpf">CPF inválido.</div>
        </div>
      </div>

      <!-- BLOCO 2: Pagamento -->
      <div class="ck-form-card">
        <div class="ck-step-title">
          <span class="ck-step-num">2</span>
          Forma de pagamento
        </div>

        <!-- Abas -->
        <div class="ck-pay-tabs">
          <button type="button" class="ck-tab ativo" id="tabPix" onclick="trocarAba('pix')">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
            </svg>
            PIX
          </button>
          <button type="button" class="ck-tab" id="tabCartao" onclick="trocarAba('cartao')">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <rect x="2" y="5" width="20" height="14" rx="2"/>
              <path d="M2 10h20"/>
            </svg>
            Cartão
          </button>
        </div>

        <!-- PAINEL PIX -->
        <div class="ck-panel ativo" id="painelPix">
          <div class="ck-pix-info">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            <div>
              Pagamento instantâneo via PIX.<br>
              <strong>Aprovação imediata</strong> após o pagamento.
            </div>
          </div>
          <button type="button" class="ck-btn-pagar" onclick="pagar('pix')">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
            Gerar QR Code PIX — {prod.preco}
          </button>
        </div>

        <!-- PAINEL CARTÃO -->
        <div class="ck-panel" id="painelCartao">
          <div class="ck-field">
            <label for="nomeCartao">Nome no cartão *</label>
            <input type="text" id="nomeCartao" placeholder="JOAO DA SILVA" autocomplete="cc-name">
          </div>
          <div class="ck-field">
            <label for="numeroCartao">Número do cartão *</label>
            <input type="text" id="numeroCartao" placeholder="0000 0000 0000 0000" maxlength="19" autocomplete="cc-number">
          </div>
          <div class="ck-field-row">
            <div class="ck-field">
              <label for="validade">Validade *</label>
              <input type="text" id="validade" placeholder="MM/AA" maxlength="5" autocomplete="cc-exp">
            </div>
            <div class="ck-field">
              <label for="cvv">CVV *</label>
              <input type="text" id="cvv" placeholder="123" maxlength="4" autocomplete="cc-csc">
            </div>
          </div>
          <div class="ck-field">
            <label for="parcelas">Parcelas</label>
            <select id="parcelas" style="width:100%;padding:11px 14px;border:1.5px solid #e2e8f0;border-radius:9px;font-size:0.92rem;color:#1a1a2e;outline:none;background:#fff">
              <option value="1">1x {prod.preco} (à vista)</option>
              <option value="2">2x de R$ {(parseFloat(prod.preco.replace('R$ ','').replace(',','.')) / 2).toFixed(2).replace('.',',')}</option>
              <option value="3">3x sem juros</option>
              <option value="6">6x sem juros</option>
              <option value="12" selected>12x {prod.parcelas}</option>
            </select>
          </div>
          <button type="button" class="ck-btn-pagar" onclick="pagar('cartao')">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="2" y="5" width="20" height="14" rx="2"/><path d="M2 10h20"/></svg>
            Pagar com Cartão — {prod.preco}
          </button>
        </div>

      </div>
    </div>

    <!-- LATERAL: Resumo do pedido -->
    <aside class="ck-side">
      <div class="ck-prod-badge">Resumo do pedido</div>
      <div class="ck-prod-nome">{prod.nome}</div>
      <div class="ck-prod-desc">{prod.desc}</div>
      <div class="ck-prod-preco">{prod.preco}</div>
      <div class="ck-prod-parc">ou {prod.parcelas} no cartão</div>

      <hr class="ck-divider">

      <div class="ck-garantia">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        <div><strong>Garantia de 7 dias</strong><br>Satisfação garantida ou seu dinheiro de volta.</div>
      </div>

      <div class="ck-bandeiras">
        <span>Visa</span>
        <span>Mastercard</span>
        <span>Elo</span>
        <span>PIX</span>
        <span>Amex</span>
      </div>
    </aside>

  </main>

  <script define:vars={{ produto, prodNome: prod.nome }}>
    // ── Formatação de inputs ──────────────────────────────
    document.getElementById('cpf').addEventListener('input', function () {
      let v = this.value.replace(/\D/g, '').slice(0, 11);
      v = v.replace(/(\d{3})(\d)/, '$1.$2');
      v = v.replace(/(\d{3})(\d)/, '$1.$2');
      v = v.replace(/(\d{3})(\d{1,2})$/, '$1-$2');
      this.value = v;
    });

    document.getElementById('telefone').addEventListener('input', function () {
      let v = this.value.replace(/\D/g, '').slice(0, 11);
      if (v.length > 10) v = v.replace(/(\d{2})(\d{5})(\d{4})/, '($1) $2-$3');
      else if (v.length > 6) v = v.replace(/(\d{2})(\d{4})(\d+)/, '($1) $2-$3');
      else if (v.length > 2) v = v.replace(/(\d{2})(\d+)/, '($1) $2');
      this.value = v;
    });

    document.getElementById('numeroCartao').addEventListener('input', function () {
      let v = this.value.replace(/\D/g, '').slice(0, 16);
      v = v.replace(/(\d{4})(?=\d)/g, '$1 ');
      this.value = v;
    });

    document.getElementById('validade').addEventListener('input', function () {
      let v = this.value.replace(/\D/g, '').slice(0, 4);
      if (v.length > 2) v = v.slice(0, 2) + '/' + v.slice(2);
      this.value = v;
    });

    // ── Troca de abas ─────────────────────────────────────
    function trocarAba(metodo) {
      ['pix', 'cartao'].forEach(m => {
        document.getElementById('tab' + (m === 'pix' ? 'Pix' : 'Cartao')).classList.toggle('ativo', m === metodo);
        document.getElementById('painel' + (m === 'pix' ? 'Pix' : 'Cartao')).classList.toggle('ativo', m === metodo);
      });
    }

    // ── Validação ────────────────────────────────────────
    function validarCampos(metodo) {
      let ok = true;

      const campos = [
        { id: 'nome', erroId: 'erroNome', check: v => v.trim().split(' ').length >= 2 },
        { id: 'email', erroId: 'erroEmail', check: v => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v) },
        { id: 'telefone', erroId: 'erroTelefone', check: v => v.replace(/\D/g,'').length >= 10 },
        { id: 'cpf', erroId: 'erroCpf', check: v => v.replace(/\D/g,'').length === 11 },
      ];

      campos.forEach(({ id, erroId, check }) => {
        const el = document.getElementById(id);
        const erro = document.getElementById(erroId);
        const valido = check(el.value);
        el.classList.toggle('erro', !valido);
        erro.style.display = valido ? 'none' : 'block';
        if (!valido) ok = false;
      });

      if (metodo === 'cartao') {
        const cartaoOk = document.getElementById('numeroCartao').value.replace(/\D/g,'').length === 16;
        if (!cartaoOk) ok = false;
      }

      return ok;
    }

    // ── Envio do pagamento ────────────────────────────────
    async function pagar(metodo) {
      if (!validarCampos(metodo)) return;

      const overlay = document.getElementById('loadingOverlay');
      overlay.classList.add('show');

      const payload = {
        produto,
        nome: document.getElementById('nome').value,
        email: document.getElementById('email').value,
        cpf: document.getElementById('cpf').value,
        telefone: document.getElementById('telefone').value,
        metodo,
      };

      if (metodo === 'cartao') {
        payload.nome_cartao = document.getElementById('nomeCartao').value;
        payload.numero_cartao = document.getElementById('numeroCartao').value;
        payload.validade = document.getElementById('validade').value;
        payload.cvv = document.getElementById('cvv').value;
        payload.parcelas = document.getElementById('parcelas').value;
      }

      try {
        const resp = await fetch('/api/criar-transacao', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });

        const data = await resp.json();
        overlay.classList.remove('show');

        if (!resp.ok) {
          mostrarModal('erro', data.erro ?? 'Erro ao processar pagamento.');
          return;
        }

        if (metodo === 'pix') {
          mostrarModalPix(data);
        } else {
          if (data.status === 'approved' || data.status === 'paid') {
            window.location.href = '/checkout/obrigado?id=' + (data.id ?? '');
          } else {
            mostrarModal('erro', 'Pagamento recusado. Verifique os dados do cartão.');
          }
        }

      } catch (err) {
        overlay.classList.remove('show');
        mostrarModal('erro', 'Falha de conexão. Tente novamente.');
      }
    }

    // ── Modais ───────────────────────────────────────────
    function mostrarModal(tipo, msg) {
      const modal = document.getElementById('modalResultado');
      document.getElementById('modalIcon').textContent = tipo === 'erro' ? '❌' : '✅';
      document.getElementById('modalTitulo').textContent = tipo === 'erro' ? 'Pagamento não efetuado' : 'Sucesso!';
      document.getElementById('modalSub').textContent = msg;
      modal.classList.add('show');
    }

    function mostrarModalPix(data) {
      const modal = document.getElementById('modalResultado');
      document.getElementById('modalIcon').textContent = '📲';
      document.getElementById('modalTitulo').textContent = 'Pague com PIX';
      document.getElementById('modalSub').textContent = 'Escaneie o QR Code ou copie o código abaixo:';

      // QR Code (campo pode variar: qr_code_url, pix_qr_code, etc.)
      const qrUrl = data.qr_code_url ?? data.pix?.qr_code_url ?? null;
      const pixCode = data.pix_copia_cola ?? data.pix?.pix_copia_cola ?? data.qr_code ?? null;

      if (qrUrl) {
        document.getElementById('qrImg').src = qrUrl;
        document.getElementById('qrcodeContainer').style.display = 'block';
      }
      if (pixCode) {
        document.getElementById('pixCopyBox').textContent = pixCode;
        document.getElementById('pixCopyBox').style.display = 'block';
        document.getElementById('btnCopiar').style.display = 'inline-block';
        window._pixCode = pixCode;
      }

      modal.classList.add('show');
    }

    function fecharModal() {
      document.getElementById('modalResultado').classList.remove('show');
    }

    function copiarPix() {
      if (window._pixCode) {
        navigator.clipboard.writeText(window._pixCode).then(() => {
          const btn = document.getElementById('btnCopiar');
          btn.textContent = '✅ Copiado!';
          setTimeout(() => btn.textContent = '📋 Copiar código PIX', 2000);
        });
      }
    }
  </script>

</body>
</html>
