---
const id = Astro.url.searchParams.get('id') ?? '';
---

<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Pedido confirmado — Synergy</title>
  <meta name="robots" content="noindex, nofollow">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background: #f0f2f5;
      color: #1a1a2e;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 24px 16px;
    }
    .card {
      background: #fff;
      border-radius: 18px;
      padding: 48px 36px;
      max-width: 440px;
      width: 100%;
      text-align: center;
      border: 1px solid #e8e8e8;
    }
    .icon { font-size: 4rem; margin-bottom: 16px; }
    h1 { font-size: 1.5rem; font-weight: 800; margin-bottom: 8px; color: #16a34a; }
    p { font-size: 0.9rem; color: #64748b; line-height: 1.6; margin-bottom: 24px; }
    .id-pedido {
      background: #f8fafc;
      border: 1px solid #e2e8f0;
      border-radius: 10px;
      padding: 10px 16px;
      font-size: 0.8rem;
      color: #475569;
      margin-bottom: 28px;
    }
    .id-pedido strong { color: #1a1a2e; font-weight: 700; }
    .btn-voltar {
      display: inline-block;
      padding: 12px 28px;
      background: #2563eb;
      color: #fff;
      border-radius: 10px;
      font-weight: 700;
      text-decoration: none;
      font-size: 0.9rem;
      transition: opacity 0.2s;
    }
    .btn-voltar:hover { opacity: 0.88; }
  </style>
</head>
<body>
  <div class="card">
    <div class="icon">🎉</div>
    <h1>Pedido confirmado!</h1>
    <p>
      Seu pagamento foi processado com sucesso.<br>
      Em breve você receberá um e-mail com os detalhes do pedido.
    </p>
    {id && (
      <div class="id-pedido">
        Código do pedido: <strong>{id}</strong>
      </div>
    )}
    <a href="/lp-secador-bettdow" class="btn-voltar">← Voltar à página</a>
  </div>
</body>
</html>
