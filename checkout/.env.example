# Bestfy Checkout - Variáveis de Ambiente

# Chave secreta da API Bestfy (encontrada em Configurações -> Credenciais de API)
BESTFY_SECRET_KEY=sua_chave_secreta_aqui

# Chave pública da API Bestfy (usada no frontend para tokenizar cartões)
BESTFY_PUBLIC_KEY=sua_chave_publica_aqui

# Porta do servidor (padrão: 3000)
PORT=3000

# Ambiente: test ou production
NODE_ENV=test

# URL base da API Bestfy
BESTFY_API_URL=https://api.bestfybr.com.br/v1

# URL do postback (opcional - recebe atualizações de status)
POSTBACK_URL=
